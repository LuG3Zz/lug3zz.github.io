<script is:inline>
  const input = document.getElementById("cmd-input");
  const toast = document.getElementById("cmd-toast");
  const toastMsg = document.getElementById("toast-msg");

  function hideToast() {
    toast.classList.remove("show");
  }

  function showToast(msg) {
    toastMsg.textContent = msg;
    toast.classList.add("show");
  }

  toast.addEventListener("click", hideToast);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") hideToast();
  });

  // Weather
  function windArrow(dir) {
    const m = { N:"↓", NNE:"↙", NE:"↙", ENE:"←", E:"←", ESE:"↖", SE:"↖", SSE:"↑", S:"↑", SSW:"↗", SW:"↗", WSW:"→", W:"→", WNW:"↘", NW:"↘", NNW:"↓" };
    return m[dir] || "―";
  }
  function weatherEmoji(desc) {
    const d = desc.toLowerCase();
    if (d.includes("sunny") || d.includes("clear") || d.includes("晴")) return "☀️";
    if (d.includes("rain") || d.includes("drizzle") || d.includes("shower") || d.includes("雨") || d.includes("阵雨")) return "🌧️";
    if (d.includes("snow") || d.includes("sleet") || d.includes("ice") || d.includes("雪") || d.includes("冰")) return "❄️";
    if (d.includes("thunder") || d.includes("storm") || d.includes("雷") || d.includes("暴")) return "⛈️";
    if (d.includes("fog") || d.includes("mist") || d.includes("haze") || d.includes("雾") || d.includes("霾")) return "🌫️";
    if (d.includes("cloud") || d.includes("overcast") || d.includes("云") || d.includes("阴")) return "☁️";
    return "🌤️";
  }
  const weatherEl = document.getElementById("weather-body");
  if (weatherEl) {
    function fetchWeather(url) {
      var ac = new AbortController();
      setTimeout(function() { ac.abort(); }, 8000);
      fetch(url, { signal: ac.signal })
        .then(function(r) { return r.json(); })
        .then(function(j) {
          var cc = j.current_condition[0];
          var city = j.nearest_area?.[0]?.areaName?.[0]?.value || "";
          var region = j.nearest_area?.[0]?.region?.[0]?.value || "";
          var loc = city + (city && region && region !== city ? ", " + region : region ? ", " + region : "");
          var desc = (cc.lang_zh?.[0]?.value) || cc.weatherDesc[0].value;
          var emoji = weatherEmoji(desc);
          var wind = windArrow(cc.winddir16Point) + " " + cc.windspeedKmph + " km/h";
          weatherEl.innerHTML = '<div>' + (loc ? loc + "  " : "") + emoji + " " + desc + '</div>' +
            '<div>🌡️ ' + cc.temp_C + '°C</div>' +
            '<div>💧 ' + cc.humidity + '%  ·  🌀 ' + wind + '</div>';
        })
        .catch(function() { weatherEl.textContent = "☁️ --.-°C"; });
    }
    var savedCity = localStorage.getItem("weather-city");
    if (savedCity) {
      fetchWeather("https://wttr.in/" + encodeURIComponent(savedCity) + "?format=j1&lang=zh");
    } else if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        function(pos) {
          // Round to 1 decimal (~11km resolution) for city-level only
          var lat = Math.round(pos.coords.latitude * 10) / 10;
          var lng = Math.round(pos.coords.longitude * 10) / 10;
          fetchWeather("https://wttr.in/" + lat + "," + lng + "?format=j1&lang=zh");
          localStorage.setItem("weather-city", lat + "," + lng);
        },
        function() { fetchWeather("https://wttr.in/?format=j1&lang=zh"); },
        { timeout: 8000, enableHighAccuracy: true }
      );
    } else {
      fetchWeather("https://wttr.in/?format=j1&lang=zh");
    }
  }

  // ─── Gist cloud sync ──────────────────────────
  var gistData = null;

  function localKey() { return "brownlu-data"; }

  function defaultGistData() {
    return { todos: [], habits: {}, moods: {}, posts: [], pomodoros: {}, passwordHash: null, encryptedPat: null };
  }

  function loadLocal() {
    try { return JSON.parse(localStorage.getItem(localKey())) || null; } catch(e) { return null; }
  }

  function saveLocal(data) {
    try { localStorage.setItem(localKey(), JSON.stringify(data)); return true; } catch(e) { return false; }
  }

  function ensureData() {
    if (!gistData) { gistData = loadLocal() || defaultGistData(); }
    return gistData;
  }

  function updatePrompt() {
    var el = document.getElementById("prompt-user");
    if (!el) return;
    el.textContent = localStorage.getItem("logged-in") === "true" ? "root" : "guest";
  }

  function sha256(str) {
    try {
      return crypto.subtle.digest("SHA-256", new TextEncoder().encode(str)).then(function(buf) {
        return Array.from(new Uint8Array(buf)).map(function(b) { return b.toString(16).padStart(2, "0"); }).join("");
      });
    } catch(e) { return Promise.resolve(str); }
  }

  function xorHex(text, keyHex) {
    var key = [];
    for (var i = 0; i < keyHex.length; i += 2) key.push(parseInt(keyHex.substring(i, i + 2), 16));
    var r = "";
    for (var i = 0; i < text.length; i++) r += String.fromCharCode(text.charCodeAt(i) ^ key[i % key.length]);
    return r;
  }
  function xorEncrypt(text, keyHex) { return btoa(xorHex(text, keyHex)); }
  function xorDecrypt(cipher, keyHex) { return xorHex(atob(cipher), keyHex); }

  function fetchGistJson(gid) {
    return fetch("https://api.github.com/gists/" + gid).then(function(res) {
      if (res.status === 401) return null;
      return res.json();
    }).then(function(json) {
      if (!json || !json.files || !json.files["data.json"]) return null;
      try { return JSON.parse(json.files["data.json"].content); } catch(e) { return null; }
    });
  }

  function loadGist(gid) {
    if (!gid) gid = localStorage.getItem("gist-id");
    if (!gid) return Promise.resolve(null);
    var key = localStorage.getItem("gist-key");
    return fetchGistJson(gid).then(function(payload) {
      if (!payload) return null;
      if (payload.v === 1 && payload.d && payload.h) {
        if (!key) return null;
        try {
          var data = JSON.parse(xorDecrypt(payload.d, key));
          if (data) gistData = data;
          return data;
        } catch(e) { return null; }
      }
      if (payload) gistData = payload;
      return payload;
    });
  }

  function findGistByUser(username) {
    return fetch("https://api.github.com/users/" + encodeURIComponent(username) + "/gists").then(function(res) {
      if (res.status !== 200) return null;
      return res.json();
    }).then(function(gists) {
      if (!Array.isArray(gists)) return null;
      for (var i = 0; i < gists.length; i++) {
        if (gists[i].files && gists[i].files["data.json"]) return { id: gists[i].id };
      }
      return null;
    }).catch(function() { return null; });
  }

  function saveGist(data) {
    var pat = localStorage.getItem("gist-pat");
    var gid = localStorage.getItem("gist-id");
    var key = localStorage.getItem("gist-key") || (data && data.passwordHash);
    gistData = data;
    var payload = data;
    if (key) payload = { v: 1, h: key, d: xorEncrypt(JSON.stringify(data), key) };
    if (pat && gid) {
      return fetch("https://api.github.com/gists/" + gid, {
        method: "PATCH",
        headers: { "Authorization": "token " + pat, "Content-Type": "application/json" },
        body: JSON.stringify({ files: { "data.json": { content: JSON.stringify(payload) } } })
      }).then(function(res) { return res.ok; }).catch(function() { saveLocal(data); return false; });
    } else { saveLocal(data); return Promise.resolve(true); }
  }

  function hasGist() {
    return localStorage.getItem("gist-pat") && localStorage.getItem("gist-id");
  }

  function strWidth(s) {
    var w = 0;
    for (var i = 0; i < s.length; i++) {
      var c = s.charCodeAt(i);
      if (c >= 0xd800 && c <= 0xdbff) { w += 2; i++; continue; }
      if (c >= 0x4e00 && c <= 0x9fff || c >= 0x3400 && c <= 0x4dbf || c >= 0x3000 && c <= 0x303f || c >= 0xff00 && c <= 0xffef || c >= 0x20000 && c <= 0x2ffff || c >= 0x2600 && c <= 0x26ff || c >= 0x2700 && c <= 0x27bf) w += 2;
      else if (c === 0xfe0f || c === 0x200d) continue;
      else w += 1;
    }
    return w;
  }

  function rep(ch, n) { return n <= 0 ? "" : Array(n + 1).join(ch); }

  function wrapBox(lines, title) {
    if (!lines || lines.length === 0) return lines;
    var maxLen = 0;
    for (var i = 0; i < lines.length; i++) maxLen = Math.max(maxLen, strWidth(lines[i]));
    var tw = title ? strWidth(title) : 0;
    var w = Math.max(maxLen + 6, tw + 10);
    var result = [];
    if (title) result.push("┌─ " + title + " " + rep("─", w - tw - 1));
    else result.push("┌" + rep("─", w + 2));
    for (var i = 0; i < lines.length; i++) {
      result.push("│ " + lines[i] + rep(" ", w - strWidth(lines[i])));
    }
    result.push("└" + rep("─", w + 2));
    return result;
  }

  function renderBar(label, value, max, total) {
    var pct = max > 0 ? value / max : 0;
    var barW = 12;
    var filled = Math.round(pct * barW);
    return " " + label + " " + rep("█", filled) + rep("░", barW - filled) + " " + value + (total ? "/" + total : "");
  }

  function parseTodoArgs(input) {
    var parts = input.split(/\s+/);
    var textParts = [], tags = [], priority = "medium", dueDate = null;
    for (var i = 0; i < parts.length; i++) {
      var p = parts[i];
      if (p === "--high") priority = "high";
      else if (p === "--low") priority = "low";
      else if (p === "--medium") priority = "medium";
      else if (p === "--due" && i + 1 < parts.length) dueDate = parts[++i];
      else if (p.startsWith("#")) tags.push(p.slice(1));
      else textParts.push(p);
    }
    return { text: textParts.join(" "), tags: tags, priority: priority, dueDate: dueDate };
  }

  function todoLine(n, t) {
    var prio = t.priority === "high" ? "[H]" : t.priority === "low" ? "[L]" : "[M]";
    var tags = (t.tags || []).map(function(tag) { return "[#" + tag + "]"; }).join("");
    var due = "";
    if (t.dueDate) {
      var diff = Math.ceil((new Date(t.dueDate) - Date.now()) / 86400000);
      due = diff > 0 ? " [📅" + diff + "d]" : diff === 0 ? " [📅today]" : " [⚠️" + (-diff) + "d]";
    }
    var mark = t.done ? "[x]" : "[ ]";
    return n + ". " + prio + tags + " " + t.text + due + "  " + mark;
  }

  function renderTodos() {
    var el = document.getElementById("todo-display");
    if (!el) return;
    if (!gistData || !gistData.todos || gistData.todos.length === 0) {
      el.style.display = "none";
      return;
    }
    var lines = [];
    for (var i = 0; i < gistData.todos.length; i++) {
      lines.push(todoLine(i + 1, gistData.todos[i]));
    }
    el.textContent = wrapBox(lines, "todo").join("\n");
    el.style.display = "block";
  }

  function renderTodoCalendar(year, month) {
    var el = document.getElementById("todo-display");
    if (!el) return;
    var dayTodo = {}, dayPomo = {}, dayItems = {};
    var dateStr = year + "-" + String(month + 1).padStart(2, "0");
    if (gistData && gistData.todos) for (var i = 0; i < gistData.todos.length; i++) {
      var t = gistData.todos[i];
      if (t.createdAt) {
        var d = new Date(t.createdAt);
        if (d.getFullYear() === year && d.getMonth() === month) {
          dayTodo[d.getDate()] = (dayTodo[d.getDate()] || 0) + 1;
          if (!dayItems[d.getDate()]) dayItems[d.getDate()] = [];
          dayItems[d.getDate()].push(t);
        }
      }
    }
    if (gistData && gistData.pomodoros) for (var key in gistData.pomodoros) if (key.startsWith(dateStr)) dayPomo[parseInt(key.slice(-2))] = gistData.pomodoros[key];
    var monthNames = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    var firstDay = (new Date(year, month, 1).getDay() + 6) % 7;
    var daysInMonth = new Date(year, month + 1, 0).getDate();
    var lines = [];
    lines.push("      " + monthNames[month] + " " + year);
    lines.push(" Mo Tu We Th Fr Sa Su");
    var week = "";
    for (var i = 0; i < firstDay; i++) week += "   ";
    for (var d = 1; d <= daysInMonth; d++) {
      var hasTodo = dayTodo[d] > 0, hasPomo = dayPomo[d] > 0;
      var marker = " ";
      if (hasTodo && hasPomo) marker = "★";
      else if (hasPomo) marker = "●";
      else if (hasTodo) marker = "·";
      week += (d < 10 ? " " : "") + d + marker;
      if ((firstDay + d) % 7 === 0 || d === daysInMonth) { lines.push(week); week = ""; }
    }
    var todoDays = Object.keys(dayTodo).length, pomoDays = Object.keys(dayPomo).length;
    lines.push(" ·todo  ●pomo  ★both  |  d:" + todoDays + " p:" + pomoDays);
    var recentDays = Object.keys(dayItems).sort(function(a, b) { return b - a; }).slice(0, 5);
    var listHtml = "";
    for (var di = 0; di < recentDays.length; di++) {
      var dayN = parseInt(recentDays[di]);
      var items = dayItems[dayN] || [];
      listHtml += '<div style="color:var(--yellow);font-size:0.75rem;margin-bottom:0.25rem;">' + monthNames[month] + " " + dayN + '</div>';
      for (var j = 0; j < items.length; j++) {
        var t = items[j];
        listHtml += '<div style="padding-left:0.5rem;font-size:0.75rem;line-height:1.5;">' + (t.done ? "[x]" : "[ ]") + " " + (t.text) + '</div>';
      }
    }
    el.innerHTML = (listHtml ? '<div style="display:flex;gap:1.5rem;align-items:flex-start;"><pre style="margin:0;background:none;border:none;padding:0;font-size:0.8125rem;white-space:pre;">' + lines.join("\n") + '</pre><div style="flex:1;min-width:0;">' + listHtml + '</div></div>' : '<pre style="margin:0;background:none;border:none;padding:0;font-size:0.8125rem;white-space:pre;">' + lines.join("\n") + '</pre>');
    el.style.display = "block";
  }

  function renderMoodCalendar() {
    var el = document.getElementById("todo-display");
    if (!el || !gistData || !gistData.moods) return;
    var today = new Date();
    var year = today.getFullYear(), month = today.getMonth();
    var daysInMonth = new Date(year, month + 1, 0).getDate();
    var monthNames = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    var firstDay = (new Date(year, month, 1).getDay() + 6) % 7;
    var moodCh = ["😞","😐","🙂","😊","😄"];
    var lines = [];
    lines.push("      " + monthNames[month] + " " + year);
    lines.push(" Mo Tu We Th Fr Sa Su");
    var week = "";
    for (var i = 0; i < firstDay; i++) week += "   ";
    for (var d = 1; d <= daysInMonth; d++) {
      var dateKey = year + "-" + String(month + 1).padStart(2, "0") + "-" + String(d).padStart(2, "0");
      var m = gistData.moods[dateKey];
      var cell = (d < 10 ? " " : "") + d + " ";
      if (m >= 1 && m <= 5) cell = moodCh[m - 1] + " ";
      else if (d === today.getDate()) cell = " ○ ";
      week += cell;
      if ((firstDay + d) % 7 === 0 || d === daysInMonth) { lines.push(week); week = ""; }
    }
    lines.push(" 😞 😐 🙂 😊 😄  ○ today no record");
    el.textContent = lines.join("\n");
    el.style.display = "block";
  }

  async function handleCommand(cmd) {
    // Clear grep results when running any command
    if (grepResults) grepResults.classList.remove("show");
    const parts = cmd.trim().split(/\s+/);
    const name = parts[0].toLowerCase();

    if (!name) return;

    if (name === "cat") {
      const slug = parts.slice(1).join(" ");
      if (!slug) {
        showToast("Usage: cat <slug>");
        return;
      }
      if (slug.includes("/")) {
        showToast("cat: " + slug + ": No such file");
        return;
      }
      window.location.href = "/blog/" + slug;
    } else if (name === "activity") {
      window.location.href = "/activity";
    } else if (name === "archive") {
      window.location.href = "/archive";
    } else if (name === "weather") {
      var wcity = parts.slice(1).join(" ");
      if (wcity) {
        localStorage.setItem("weather-city", wcity);
        window.location.reload();
      } else {
        var cur = localStorage.getItem("weather-city");
        showToast(cur ? "weather: " + cur + " (type 'weather <city>' to change)" : "weather: auto (type 'weather <city>' to set)");
      }
    } else if (name === "theme") {
      var tname = parts.slice(1).join(" ");
      var themes = ["terminal","catppuccin","matrix","nord","gruvbox","dracula","tokyo-night","one-dark"];
      if (!tname) {
        showToast("theme: " + (localStorage.getItem("theme") || "terminal") + " (" + themes.join("/") + ")");
      } else if (themes.indexOf(tname) !== -1) {
        document.documentElement.setAttribute("data-theme", tname);
        localStorage.setItem("theme", tname);
        themeSelect.value = tname;
        showToast("theme set to " + tname);
      } else {
        showToast("theme: unknown theme \"" + tname + "\" (" + themes.join("/") + ")");
      }
    } else if (name === "travel") {
      window.location.href = "/travel";
    } else if (name === "downloads") {
      window.location.href = "/downloads";
    } else if (name === "scripts") {
      window.location.href = "/scripts";
    } else if (name === "ls") {
      window.location.href = "/blog";
    } else if (name === "whoami") {
      window.location.href = "/about";
    } else if (name === "get") {
      const script = parts.slice(1).join(" ");
      if (!script) {
        window.location.href = "/scripts";
      } else {
        window.location.href = `/scripts/${script}`;
      }
    } else if (name === "help") {
      showToast("cat | cd | tag | grep | series | theme | login | todo | pomo | clear");
    } else if (name === "clear") {
      hideSuggestions();
      if (grepResults) grepResults.classList.remove("show");
      document.getElementById("pomodoro-display").style.display = "none";
      input.value = "";
      input.focus();
    } else if (name === "date") {
      const now = new Date();
      showToast(now.toLocaleString("zh-CN", { timeZone: "Asia/Shanghai" }));
    } else if (name === "series") {
      const s = parts.slice(1).join(" ");
      if (!s) {
        window.location.href = "/series";
      } else {
        window.location.href = "/series/" + s;
      }
    } else if (name === "tag") {
      const tag = parts.slice(1).join(" ");
      if (!tag) {
        window.location.href = "/tags";
      } else {
        window.location.href = `/tags/${tag}`;
      }
    } else if (name === "cd") {
      const knownPaths = ["/", "/home", "/blog", "/tags", "/todo", "/now", "/dashboard", "/travel", "/activity", "/archive", "/search", "/scripts", "/downloads", "/about"];
      const knownPrefixes = ["/tags/", "/blog/", "/scripts/"];
      const target = parts.slice(1).join(" ");
      let path;
      if (!target || target === "/" || target === "~" || target === "home") {
        path = "/";
      } else if (target === "..") {
        const current = window.location.pathname.replace(/\/$/, "");
        path = current.substring(0, current.lastIndexOf("/")) || "/";
      } else {
        path = target.startsWith("/") ? target : "/" + target;
      }
      path = path.replace(/\/$/, "") || "/";
      const valid = knownPaths.includes(path) || knownPrefixes.some(function(p) { return path.startsWith(p); });
      if (valid) {
        window.location.href = path;
      } else {
        showToast("cd: " + path + ": No such directory");
      }
    } else if (name === "grep") {
      const q = parts.slice(1).join(" ");
      if (!q) { showToast("Usage: grep <query>"); return; }
      showGrepResults(q);
    } else if (name === "fortune") {
      const qs = JSON.parse(document.getElementById("fortune-data").textContent);
      const q = qs[Math.floor(Math.random() * qs.length)];
      showToast('"' + q.text + '"' + (q.author ? " — " + q.author : ""));
    } else if (name === "zen") {
      var on = document.documentElement.getAttribute("data-zen") !== "true";
      document.documentElement.setAttribute("data-zen", on ? "true" : "false");
      localStorage.setItem("zen", on ? "true" : "false");
      showToast(on ? "zen mode on" : "zen mode off");
    } else if (name === "uptime") {
      var start = new Date(document.getElementById("uptime-data").getAttribute("data-start"));
      var now = new Date();
      var diff = Math.floor((now.getTime() - start.getTime()) / 1000);
      var days = Math.floor(diff / 86400);
      var hours = Math.floor((diff % 86400) / 3600);
      var mins = Math.floor((diff % 3600) / 60);
      showToast("uptime: " + days + " days, " + hours + " hours, " + mins + " mins");
    } else if (name === "tip") {
      var tips = [
        "Use '!!' to re-run the last command: sudo !!",
