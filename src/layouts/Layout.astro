  input.addEventListener("keydown", function(e) {
    if (e.key === "Tab") {
      e.preventDefault();
      var val = input.value;
      var trimmed = val.trim();
      var parts = trimmed.split(/\s+/);
      var cmd = parts[0].toLowerCase();
      var completingCmd = parts.length === 1 && !val.endsWith(" ") || tabIsCmd;
      var partial = completingCmd ? (tabIsCmd ? tabPartial : trimmed) : (tabMatches.length ? tabPartial : parts[parts.length - 1] || "");
      var candidates = completingCmd ? commands_list : (argMap[cmd] || []);
      var matches = candidates.filter(function(c) { return c.startsWith(partial); });
      if (matches.length === 1) {
        input.value = completingCmd ? matches[0] + " " : val.replace(/\S+$/, "") + matches[0] + " ";
        hideSuggestions();
      } else if (matches.length > 1) {
        if (tabMatches.length !== matches.length || !tabMatches.every(function(v, i) { return v === matches[i]; })) {
          tabMatches = matches; tabPartial = partial; tabIndex = -1; tabIsCmd = completingCmd;
        }
        tabIndex = (tabIndex + 1) % matches.length;
        input.value = completingCmd ? tabMatches[tabIndex] + " " : val.replace(/\S+$/, "") + tabMatches[tabIndex];
        showSuggestions(matches);
        highlightSug(tabIndex);
      } else {
        hideSuggestions();
      }
      histIndex = -1;
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      var history = JSON.parse(localStorage.getItem("cmd-history") || "[]");
      if (history.length === 0) return;
      if (histIndex === -1) histIndex = history.length;
      if (histIndex > 0) histIndex--;
      else return;
      input.value = history[histIndex];
      setTimeout(function() { input.setSelectionRange(input.value.length, input.value.length); }, 0);
    } else if (e.key === "ArrowDown") {
      e.preventDefault();
      var history = JSON.parse(localStorage.getItem("cmd-history") || "[]");
      if (histIndex === -1) { input.value = ""; return; }
      histIndex++;
      if (histIndex >= history.length) { histIndex = -1; input.value = ""; return; }
      input.value = history[histIndex];
      setTimeout(function() { input.setSelectionRange(input.value.length, input.value.length); }, 0);
    } else if (e.key === "Escape") {
      hideSuggestions();
    } else if (e.key === "Enter") {
      e.preventDefault();
      hideSuggestions();
      var cmdVal = input.value.trim();
      if (cmdVal) {
        var history = JSON.parse(localStorage.getItem("cmd-history") || "[]");
        if (!history.length || history[history.length - 1] !== cmdVal) { history.push(cmdVal); if (history.length > 50) history = history.slice(-50); localStorage.setItem("cmd-history", JSON.stringify(history)); }
      }
      histIndex = -1;
      handleCommand(input.value);
      input.value = "";
    } else {
      histIndex = -1;
      hideSuggestions();
      if (grepResults) grepResults.classList.remove("show");
    }
  });

