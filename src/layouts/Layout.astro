---
import "../styles/terminal.css";
const { title } = Astro.props;
const path = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <script is:inline>
    (function(){
      document.documentElement.setAttribute("data-theme",localStorage.getItem("theme")||"terminal");
      if (localStorage.getItem("zen") === "true") document.documentElement.setAttribute("data-zen","true");
    })();
  </script>
  <style>
    :root { --bg:#0d0d0d;--fg:#c0c0c0;--fg-bright:#fff;--green:#33ff33;--yellow:#ffff33;--red:#ff3333;--blue:#33aaff;--dim:#666;--border:#333;--cursor:#33ff33;--selection:rgba(255,255,255,0.15);--font-mono:"JetBrains Mono","Fira Code","Cascadia Code","Consolas","Noto Sans SC","PingFang SC","Microsoft YaHei","WenQuanYi Micro Hei",monospace; }
    [data-theme="catppuccin"]{--bg:#1e1e2e;--fg:#cdd6f4;--fg-bright:#fff;--green:#a6e3a1;--yellow:#f9e2af;--red:#f38ba8;--blue:#89b4fa;--dim:#6c7086;--border:#45475a;--cursor:#b4befe;--selection:rgba(180,190,254,0.2)}
    [data-theme="matrix"]{--bg:#000;--fg:#00cc00;--fg-bright:#00ff00;--green:#00ff00;--yellow:#00cc00;--red:#009900;--blue:#006600;--dim:#004400;--border:#003300;--cursor:#00ff00;--selection:rgba(0,255,0,0.3)}
    [data-theme="nord"]{--bg:#2e3440;--fg:#d8dee9;--fg-bright:#eceff4;--green:#a3be8c;--yellow:#ebcb8b;--red:#bf616a;--blue:#81a1c1;--dim:#4c566a;--border:#434c5e;--cursor:#d8dee9;--selection:rgba(216,222,233,0.15)}
    [data-theme="gruvbox"]{--bg:#282828;--fg:#ebdbb2;--fg-bright:#d5c4a1;--green:#b8bb26;--yellow:#fabd2f;--red:#fb4934;--blue:#83a598;--dim:#928374;--border:#3c3836;--cursor:#ebdbb2;--selection:rgba(235,219,178,0.2)}
  </style>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — brownlu-blog</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💻</text></svg>" />
</head>
<body>
  <div class="container">
    <header class="terminal-header">
      <div class="header-top">
        <div class="ascii-art">  _                             _
 | |__  _ __ _____      ___ __ | |_   _
 | '_ \| '__/ _ \ \ /\ / / '_ \| | | | |
 | |_) | | | (_) \ V  V /| | | | | |_| |
 |_.__/|_|  \___/ \_/\_/ |_| |_|_|\__,_|</div>
        {path === "/" && (
          <div class="weather-box">
            <div class="weather-title">$ curl wttr.in</div>
            <div class="weather-body" id="weather-body"><span class="weather-loading">fetching...</span></div>
          </div>
        )}
      </div>

      <div class="terminal-line">
        <span class="prompt">
          <span class="prompt-user">guest</span>
          <span class="prompt-at">@</span>
          <span class="prompt-host">brownlu-blog</span>
        </span>
        <span class="prompt-sep"> ~ </span>
        <span class="prompt-dir">/{path === "/" ? "" : path.replace(/\/$/, "").replace(/^\//, "") || "~"}</span>
        <span class="prompt-end"> $</span>
        <input type="text" id="cmd-input" class="cmd-input" autofocus spellcheck="false" autocomplete="off" />
      </div>

      <div id="cmd-suggestions" class="cmd-suggestions"></div>

      <nav class="nav">
        <a href="/" class={path === "/" ? "active" : ""}>home</a>
        <a href="/blog" class={path.startsWith("/blog") ? "active" : ""}>blog</a>
        <a href="/tags" class={path.startsWith("/tags") ? "active" : ""}>tags</a>
        <a href="/activity" class={path === "/activity" ? "active" : ""}>activity</a>
        <a href="/travel" class={path === "/travel" ? "active" : ""}>travel</a>
        <a href="/scripts" class={path === "/scripts" ? "active" : ""}>scripts</a>
        <a href="/downloads" class={path === "/downloads" ? "active" : ""}>downloads</a>
        <a href="/about" class={path === "/about" ? "active" : ""}>about</a>
        <span class="theme-selector-wrap">
          <select id="theme-select" class="theme-select">
            <option value="terminal">terminal</option>
            <option value="catppuccin">catppuccin</option>
            <option value="matrix">matrix</option>
            <option value="nord">nord</option>
            <option value="gruvbox">gruvbox</option>
          </select>
        </span>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="terminal-footer">
      <div class="terminal-line">
        <span class="prompt-end">$</span>
        <span>echo "EOF"</span>
        <span class="cursor-block cursor-blink"></span>
      </div>
      <div style="margin-top: 0.5rem;">
        <a href="https://github.com/LuG3Zz">github</a>
        &nbsp;·&nbsp;
        <span>powered by Astro</span>
        &nbsp;·&nbsp;
        <span>© {new Date().getFullYear()}</span>
      </div>
    </footer>
  </div>

  <div id="cmd-toast" class="cmd-toast"><span id="toast-msg"></span><span class="dismiss">[x]</span></div>
</body>
</html>

<style>
  .ascii-art { line-height: 1.1; }
  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .weather-box {
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    text-align: left;
    flex-shrink: 0;
  }
  .weather-title {
    color: var(--dim);
    font-size: 0.75rem;
    margin-bottom: 0.25rem;
  }
  .weather-body {
    color: var(--green);
    font-size: 0.8125rem;
    margin: 0;
    background: none;
    border: none;
    padding: 0;
  }
  .weather-loading {
    color: var(--dim);
  }
  .theme-selector-wrap { margin-left: auto; }
  .theme-select {
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.25rem 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    cursor: pointer;
    outline: none;
  }
  .theme-select:hover {
    border-color: var(--green);
  }
  .theme-select option {
    background: var(--bg);
    color: var(--fg);
  }
  .cmd-input {
    flex: 1;
    min-width: 80px;
    background: none;
    border: none;
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 1rem;
    outline: none;
    caret-color: var(--cursor);
  }
  .cmd-toast {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    background: #1a1a1a;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem 1.5rem;
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    display: none;
    cursor: pointer;
    z-index: 100;
    user-select: none;
  }
  .cmd-toast.show {
    display: block;
  }
  .cmd-suggestions {
    display: none;
    margin-top: 0.25rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--yellow);
    animation: slideDown 0.15s ease-out;
    white-space: nowrap;
    overflow-x: auto;
  }
  .cmd-suggestions.show { display: inline-block; }
  .cmd-suggestions .sug-item { cursor: pointer; transition: color 0.1s; }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .cmd-toast .dismiss {
    color: var(--dim);
    margin-left: 1rem;
  }
</style>

<script>
  const input = document.getElementById("cmd-input");
  const toast = document.getElementById("cmd-toast");
  const toastMsg = document.getElementById("toast-msg");

  function hideToast() {
    toast.classList.remove("show");
  }

  function showToast(msg) {
    toastMsg.textContent = msg;
    toast.classList.add("show");
  }

  toast.addEventListener("click", hideToast);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") hideToast();
  });

  // Weather
  function windArrow(dir) {
    const m = { N:"↓", NNE:"↙", NE:"↙", ENE:"←", E:"←", ESE:"↖", SE:"↖", SSE:"↑", S:"↑", SSW:"↗", SW:"↗", WSW:"→", W:"→", WNW:"↘", NW:"↘", NNW:"↓" };
    return m[dir] || "―";
  }
  function weatherEmoji(desc) {
    const d = desc.toLowerCase();
    if (d.includes("sunny") || d.includes("clear")) return "☀️";
    if (d.includes("rain") || d.includes("drizzle") || d.includes("shower")) return "🌧️";
    if (d.includes("snow") || d.includes("sleet") || d.includes("ice")) return "❄️";
    if (d.includes("thunder") || d.includes("storm")) return "⛈️";
    if (d.includes("fog") || d.includes("mist") || d.includes("haze")) return "🌫️";
    if (d.includes("cloud") || d.includes("overcast")) return "☁️";
    return "🌤️";
  }
  const weatherEl = document.getElementById("weather-body");
  if (weatherEl) {
    const ac = new AbortController();
    setTimeout(() => ac.abort(), 8000);
    fetch("https://wttr.in/?format=j1&lang=zh", { signal: ac.signal })
      .then((r) => r.json())
      .then((j) => {
        const cc = j.current_condition[0];
        const city = j.nearest_area?.[0]?.region?.[0]?.value || j.nearest_area?.[0]?.areaName?.[0]?.value || "";
        const desc = (cc.lang_zh?.[0]?.value) || cc.weatherDesc[0].value;
        const emoji = weatherEmoji(desc);
        const wind = windArrow(cc.winddir16Point) + " " + cc.windspeedKmph + " km/h";
        weatherEl.textContent = (city ? city + "  " : "") + emoji + " " + desc + "  ·  " + cc.temp_C + "°C  ·  💧 " + cc.humidity + "%  ·  " + wind;
      })
      .catch(() => { weatherEl.textContent = "--.-°C"; });
  }

  function handleCommand(cmd) {
    const parts = cmd.trim().split(/\s+/);
    const name = parts[0].toLowerCase();

    if (!name) return;

    if (name === "cat") {
      const slug = parts.slice(1).join(" ");
      if (!slug) {
        showToast("Usage: cat <slug>");
        return;
      }
      if (slug.includes("/")) {
        showToast("cat: " + slug + ": No such file");
        return;
      }
      window.location.href = "/blog/" + slug;
    } else if (name === "activity" || name === "heatmap") {
      window.location.href = "/activity";
    } else if (name === "travel") {
      window.location.href = "/travel";
    } else if (name === "downloads") {
      window.location.href = "/downloads";
    } else if (name === "scripts") {
      window.location.href = "/scripts";
    } else if (name === "ls") {
      window.location.href = "/blog";
    } else if (name === "whoami") {
      window.location.href = "/about";
    } else if (name === "get") {
      const script = parts.slice(1).join(" ");
      if (!script) {
        window.location.href = "/scripts";
      } else {
        window.location.href = `/scripts/${script}`;
      }
    } else if (name === "help") {
      showToast("ls | cat <slug> | cd <path> | get <script> | whoami | date | tag <name> | activity | downloads | clear");
    } else if (name === "clear") {
      window.location.reload();
    } else if (name === "date") {
      const now = new Date();
      showToast(now.toLocaleString("zh-CN", { timeZone: "Asia/Shanghai" }));
    } else if (name === "tag") {
      const tag = parts.slice(1).join(" ");
      if (!tag) {
        window.location.href = "/tags";
      } else {
        window.location.href = `/tags/${tag}`;
      }
    } else if (name === "cd") {
      const knownPaths = ["/", "/home", "/blog", "/tags", "/travel", "/activity", "/scripts", "/downloads", "/about"];
      const knownPrefixes = ["/tags/", "/blog/", "/scripts/"];
      const target = parts.slice(1).join(" ");
      let path;
      if (!target || target === "/" || target === "~" || target === "home") {
        path = "/";
      } else if (target === "..") {
        const current = window.location.pathname.replace(/\/$/, "");
        path = current.substring(0, current.lastIndexOf("/")) || "/";
      } else {
        path = target.startsWith("/") ? target : "/" + target;
      }
      path = path.replace(/\/$/, "") || "/";
      const valid = knownPaths.includes(path) || knownPrefixes.some(function(p) { return path.startsWith(p); });
      if (valid) {
        window.location.href = path;
      } else {
        showToast("cd: " + path + ": No such directory");
      }
    } else if (name === "zen") {
      var on = document.documentElement.getAttribute("data-zen") !== "true";
      document.documentElement.setAttribute("data-zen", on ? "true" : "false");
      localStorage.setItem("zen", on ? "true" : "false");
      showToast(on ? "zen mode on" : "zen mode off");
    } else {
      showToast(`command not found: ${name}. Type 'help'`);
    }
  }

  var commands_list = ["cat","ls","cd","whoami","date","clear","help","tag","get","scripts","downloads","travel","activity","heatmap","home","zen"];
  var suggestions = document.getElementById("cmd-suggestions");

  var tabMatches = [];
  var tabIndex = -1;

  function showSuggestions(items) {
    tabMatches = items;
    tabIndex = -1;
    var html = "";
    for (var i = 0; i < items.length; i++) {
      html += '<span class="sug-item" data-idx="' + i + '">' + items[i] + "</span>";
      if (i < items.length - 1) html += "  ";
    }
    suggestions.innerHTML = html;
    suggestions.classList.add("show");
  }
  function hideSuggestions() {
    suggestions.classList.remove("show");
    tabMatches = [];
    tabIndex = -1;
  }
  function highlightSug(idx) {
    var items = suggestions.querySelectorAll(".sug-item");
    items.forEach(function(el, i) {
      el.style.color = i === idx ? "var(--green)" : "";
      el.style.textDecoration = i === idx ? "underline" : "";
    });
  }

  input.addEventListener("input", hideSuggestions);
  input.addEventListener("keydown", function(e) {
    if (e.key === "Tab") {
      e.preventDefault();
      var val = input.value.trim();
      var parts = val.split(/\s+/);
      if (parts.length <= 1) {
        var matches = commands_list.filter(function(c) { return c.startsWith(val); });
        if (matches.length === 1) {
          hideSuggestions();
          input.value = matches[0] + " ";
        } else if (matches.length > 1) {
          if (tabMatches.length === matches.length && tabMatches.every(function(v, i) { return v === matches[i]; })) {
            tabIndex = (tabIndex + 1) % matches.length;
          } else {
            tabMatches = matches;
            tabIndex = 0;
          }
          input.value = tabMatches[tabIndex] + " ";
          showSuggestions(matches);
          highlightSug(tabIndex);
        } else {
          hideSuggestions();
        }
      }
    } else if (e.key === "Escape") {
      hideSuggestions();
    } else if (e.key === "Enter") {
      hideSuggestions();
      handleCommand(input.value);
      input.value = "";
    }
  });

  document.addEventListener("click", function(e) {
    hideSuggestions();
    if (e.target.tagName !== "A" && e.target.tagName !== "IMG" && !window.getSelection().toString()) {
      input.focus();
    }
  });

  // Theme switcher
  const themeSelect = document.getElementById("theme-select");
  themeSelect.value = localStorage.getItem("theme") || "terminal";
  themeSelect.addEventListener("change", () => {
    const theme = themeSelect.value;
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem("theme", theme);
  });
</script>
