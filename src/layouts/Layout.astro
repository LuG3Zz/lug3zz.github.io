  var commands_list = ["activity","archive","cat","cd","clear","dashboard","date","downloads","focus","fortune","get","gist-setup","grep","habit","help","login","logout","ls","matrix","mood","night","pomodoro","pomo","post","rand","save","scripts","series","tag","theme","tip","todo","travel","uptime","weather","whoami","zen"];
