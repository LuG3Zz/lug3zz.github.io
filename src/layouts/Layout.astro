---
import "../styles/terminal.css";
import { getCollection } from "astro:content";
import { readdirSync, readFileSync } from "fs";
import { join } from "path";
const { title } = Astro.props;
const path = Astro.url.pathname;

const allPosts = await getCollection("blog");
const slugs = allPosts.map(p => p.slug);
const tags = [...new Set(allPosts.flatMap(p => p.data.tags ?? []))];
const series = [...new Set(allPosts.map(p => p.data.series).filter(Boolean))];
const scripts = readdirSync(join(process.cwd(), "public/scripts")).map(f => f.replace(/\.\w+$/, ""));
const completionJson = JSON.stringify({ slugs, tags, series, scripts });

// Get first commit date for uptime
const firstCommitDate = "2026-04-28T22:28:26+08:00";

const searchIndex = allPosts.map((p) => {
  const fp = join(process.cwd(), "src/content/blog", p.id);
  let content = "";
  try { content = readFileSync(fp, "utf-8"); } catch (_) {}
  return {
    slug: p.slug,
    title: p.data.title,
    description: p.data.description ?? "",
    tags: p.data.tags ?? [],
    date: p.data.date.toISOString().slice(0, 10),
    content: content.replace(/---[\s\S]*?---/, "").trim(),
  };
});
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <script is:inline>
    (function(){
      document.documentElement.setAttribute("data-theme",localStorage.getItem("theme")||"terminal");
      if (localStorage.getItem("zen") === "true") document.documentElement.setAttribute("data-zen","true");
      if (localStorage.getItem("focus") === "true") document.documentElement.setAttribute("data-focus","true");
      if (localStorage.getItem("night") === "true") document.documentElement.setAttribute("data-night","true");
      else {
        var h = new Date().getHours();
        if (h >= 22 || h < 6) document.documentElement.setAttribute("data-night","true");
      }
    })();
  </script>
  <style>
    :root { --bg:#0d0d0d;--fg:#c0c0c0;--fg-bright:#fff;--green:#33ff33;--yellow:#ffff33;--red:#ff3333;--blue:#33aaff;--cyan:#33ffff;--dim:#666;--border:#333;--cursor:#33ff33;--selection:rgba(255,255,255,0.15);--font-mono:"JetBrains Mono","Fira Code","Cascadia Code","Consolas","Noto Sans SC","PingFang SC","Microsoft YaHei","WenQuanYi Micro Hei",monospace; }
    [data-theme="catppuccin"]{--bg:#1e1e2e;--fg:#cdd6f4;--fg-bright:#fff;--green:#a6e3a1;--yellow:#f9e2af;--red:#f38ba8;--blue:#89b4fa;--cyan:#89dceb;--dim:#6c7086;--border:#45475a;--cursor:#b4befe;--selection:rgba(180,190,254,0.2)}
    [data-theme="matrix"]{--bg:#000;--fg:#00cc00;--fg-bright:#00ff00;--green:#00ff00;--yellow:#00cc00;--red:#009900;--blue:#006600;--cyan:#00cc66;--dim:#004400;--border:#003300;--cursor:#00ff00;--selection:rgba(0,255,0,0.3)}
    [data-theme="nord"]{--bg:#2e3440;--fg:#d8dee9;--fg-bright:#eceff4;--green:#a3be8c;--yellow:#ebcb8b;--red:#bf616a;--blue:#81a1c1;--cyan:#88c0d0;--dim:#4c566a;--border:#434c5e;--cursor:#d8dee9;--selection:rgba(216,222,233,0.15)}
    [data-theme="gruvbox"]{--bg:#282828;--fg:#ebdbb2;--fg-bright:#d5c4a1;--green:#b8bb26;--yellow:#fabd2f;--red:#fb4934;--blue:#83a598;--cyan:#8ec07c;--dim:#928374;--border:#3c3836;--cursor:#ebdbb2;--selection:rgba(235,219,178,0.2)}
  </style>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — brownlu-blog</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💻</text></svg>" />
</head>
<body>
  <div class="container">
    <header class="terminal-header">
      <div class="header-top">
        <div class="ascii-art">  _                             _
 | |__  _ __ _____      ___ __ | |_   _
 | '_ \| '__/ _ \ \ /\ / / '_ \| | | | |
 | |_) | | | (_) \ V  V /| | | | | |_| |
 |_.__/|_|  \___/ \_/\_/ |_| |_|_|\__,_|</div>
        {path === "/" && (
          <div class="weather-box">
            <div class="weather-title">$ curl wttr.in</div>
            <div class="weather-body" id="weather-body"><span class="weather-loading">fetching...</span></div>
          </div>
        )}
      </div>

      <div class="terminal-line">
        <form id="cmd-form" style="display:contents;" onsubmit="return false;">
        <span class="prompt">
          <span class="prompt-user">guest</span>
          <span class="prompt-at">@</span>
          <span class="prompt-host">brownlu-blog</span>
        </span>
        <span class="prompt-sep"> ~ </span>
        <span class="prompt-dir">/{path === "/" ? "" : path.replace(/\/$/, "").replace(/^\//, "") || "~"}</span>
        <span class="prompt-end"> $</span>
        <input type="text" id="cmd-input" class="cmd-input" spellcheck="false" autocomplete="off" />
        <select id="theme-select" class="theme-select" style="margin-left:0.5rem;flex-shrink:0;">
          <option value="terminal">terminal</option>
          <option value="catppuccin">catppuccin</option>
          <option value="matrix">matrix</option>
          <option value="nord">nord</option>
          <option value="gruvbox">gruvbox</option>
        </select>
        </form>
      </div>

      <div id="cmd-suggestions" class="cmd-suggestions"></div>
      <div id="grep-results" class="grep-results"></div>

      <nav class="nav">
        <a href="/" class={path === "/" ? "active" : ""}>home</a>
        <a href="/blog" class={path.startsWith("/blog") ? "active" : ""}>blog</a>
        <a href="/tags" class={path.startsWith("/tags") ? "active" : ""}>tags</a>
        <a href="/series" class={path.startsWith("/series") ? "active" : ""}>series</a>
        <a href="/activity" class={path === "/activity" ? "active" : ""}>activity</a>
        <a href="/archive" class={path === "/archive" ? "active" : ""}>archive</a>
        <a href="/travel" class={path === "/travel" ? "active" : ""}>travel</a>

        <a href="/about" class={path === "/about" ? "active" : ""}>about</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="terminal-footer">
      <div class="terminal-line">
        <span class="prompt-end">$</span>
        <span>echo "EOF"</span>
        <span class="cursor-block cursor-blink"></span>
      </div>
      <div style="margin-top: 0.5rem;">
        <a href="https://github.com/LuG3Zz">github</a>
        &nbsp;·&nbsp;
        <span>powered by Astro</span>
        &nbsp;·&nbsp;
        <span>© {new Date().getFullYear()}</span>
        &nbsp;·&nbsp;
        <span>uptime: <span id="footer-uptime">--</span></span>
      </div>
    </footer>
  </div>

  <div id="cmd-toast" class="cmd-toast"><span id="toast-msg"></span><span class="dismiss">[x]</span></div>
  <span id="uptime-data" style="display:none;" data-start={firstCommitDate}></span>
  <button id="back-to-top" class="back-to-top" aria-label="Back to top">^</button>

  <script id="completion-data" type="application/json" set:html={completionJson}></script>
  <script id="search-index" type="application/json" set:html={JSON.stringify(searchIndex)}></script>
  <script is:inline id="fortune-data" type="application/json">[
    {"text":"Talk is cheap. Show me the code.","author":"Linus Torvalds"},
    {"text":"任何傻瓜都能写出计算机能理解的代码。优秀的程序员写的是人类能读懂的代码。","author":"Martin Fowler"},
    {"text":"先有 Hello World，后有万水千山。","author":""},
    {"text":"Simplicity is prerequisite for reliability.","author":"Edsger W. Dijkstra"},
    {"text":"程序是写给人读的，顺便能在机器上跑。","author":"Harold Abelson"},
    {"text":"在终端里，没有不可能的事，只有还没敲的命令。","author":""},
    {"text":"Debugging is twice as hard as writing the code in the first place.","author":"Brian Kernighan"},
    {"text":"打字是程序员最好的健身。","author":""},
    {"text":"The best way to predict the future is to invent it.","author":"Alan Kay"},
    {"text":"删除代码不是损失，是获得。","author":""},
    {"text":"Keep it simple, stupid.","author":""},
    {"text":"代码如诗，终端如画。","author":""},
    {"text":"A journey of a thousand miles begins with a single step.","author":"Lao Tzu"},
    {"text":"别重复造轮子，除非你想学习轮子的工作原理。","author":""},
    {"text":"It works on my machine.","author":""},
    {"text":"所谓程序员，就是一台将咖啡因转化为代码的机器。","author":""},
    {"text":"The only way to learn a new programming language is by writing programs in it.","author":"Dennis Ritchie"},
    {"text":"先让它跑起来，再让它跑得快。","author":""},
    {"text":"读代码比写代码更难。所以如果你写不出干净的代码，你就看不懂你写了什么。","author":""},
    {"text":"在这终端里，你就是 root。","author":""}
  ]</script>
</body>
</html>

<style>
  .ascii-art { line-height: 1.1; }
  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .weather-box {
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    text-align: left;
    flex-shrink: 0;
  }
  .weather-title {
    color: var(--dim);
    font-size: 0.75rem;
    margin-bottom: 0.25rem;
  }
  .weather-body {
    color: var(--green);
    font-size: 0.8125rem;
    margin: 0;
    background: none;
    border: none;
    padding: 0;
  }
  .weather-loading {
    color: var(--dim);
  }
  .theme-select {
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.25rem 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    cursor: pointer;
    outline: none;
  }
  .theme-select:hover {
    border-color: var(--green);
  }
  .theme-select option {
    background: var(--bg);
    color: var(--fg);
  }
  .cmd-input {
    flex: 1;
    min-width: 80px;
    background: none;
    border: none;
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 1rem;
    outline: none;
    caret-color: var(--cursor);
  }
  .cmd-toast {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    background: #1a1a1a;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem 1.5rem;
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    display: none;
    cursor: pointer;
    z-index: 100;
    user-select: none;
  }
  .cmd-toast.show {
    display: block;
  }
  .cmd-suggestions {
    display: none;
    margin-top: 0.25rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--yellow);
    animation: slideDown 0.15s ease-out;
    white-space: nowrap;
    overflow-x: auto;
  }
  .cmd-suggestions.show { display: inline-block; }
  .cmd-suggestions .sug-item { cursor: pointer; transition: color 0.1s; }
  .grep-results {
    display: none;
    margin-top: 0.25rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    max-height: 300px;
    overflow-y: auto;
  }
  .grep-results.show { display: block; }
  .grep-results .gr-item {
    display: block;
    padding: 0.3rem 0;
    color: var(--fg);
    text-decoration: none;
    line-height: 1.6;
  }
  .grep-results .gr-item:hover { color: var(--green); }
  .grep-results .gr-item .gr-title { color: var(--yellow); }
  .grep-results .gr-item .gr-desc { color: var(--dim); font-size: 0.75rem; }
  .grep-results .gr-stats { color: var(--dim); font-size: 0.75rem; margin-bottom: 0.4rem; }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .cmd-toast .dismiss {
    color: var(--dim);
    margin-left: 1rem;
  }
  .back-to-top {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--bg);
    color: var(--green);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 1.25rem;
    cursor: pointer;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.2s, transform 0.2s;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .back-to-top.show {
    opacity: 1;
    transform: translateY(0);
  }
  .back-to-top:hover {
    border-color: var(--green);
    background: #1a1a1a;
  }
</style>

<script>
  const input = document.getElementById("cmd-input");
  const toast = document.getElementById("cmd-toast");
  const toastMsg = document.getElementById("toast-msg");

  function hideToast() {
    toast.classList.remove("show");
  }

  function showToast(msg) {
    toastMsg.textContent = msg;
    toast.classList.add("show");
  }

  toast.addEventListener("click", hideToast);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") hideToast();
  });

  // Weather
  function windArrow(dir) {
    const m = { N:"↓", NNE:"↙", NE:"↙", ENE:"←", E:"←", ESE:"↖", SE:"↖", SSE:"↑", S:"↑", SSW:"↗", SW:"↗", WSW:"→", W:"→", WNW:"↘", NW:"↘", NNW:"↓" };
    return m[dir] || "―";
  }
  function weatherEmoji(desc) {
    const d = desc.toLowerCase();
    if (d.includes("sunny") || d.includes("clear") || d.includes("晴")) return "☀️";
    if (d.includes("rain") || d.includes("drizzle") || d.includes("shower") || d.includes("雨") || d.includes("阵雨")) return "🌧️";
    if (d.includes("snow") || d.includes("sleet") || d.includes("ice") || d.includes("雪") || d.includes("冰")) return "❄️";
    if (d.includes("thunder") || d.includes("storm") || d.includes("雷") || d.includes("暴")) return "⛈️";
    if (d.includes("fog") || d.includes("mist") || d.includes("haze") || d.includes("雾") || d.includes("霾")) return "🌫️";
    if (d.includes("cloud") || d.includes("overcast") || d.includes("云") || d.includes("阴")) return "☁️";
    return "🌤️";
  }
  const weatherEl = document.getElementById("weather-body");
  if (weatherEl) {
    function fetchWeather(url) {
      var ac = new AbortController();
      setTimeout(function() { ac.abort(); }, 8000);
      fetch(url, { signal: ac.signal })
        .then(function(r) { return r.json(); })
        .then(function(j) {
          var cc = j.current_condition[0];
          var city = j.nearest_area?.[0]?.areaName?.[0]?.value || "";
          var region = j.nearest_area?.[0]?.region?.[0]?.value || "";
          var loc = city + (city && region && region !== city ? ", " + region : region ? ", " + region : "");
          var desc = (cc.lang_zh?.[0]?.value) || cc.weatherDesc[0].value;
          var emoji = weatherEmoji(desc);
          var wind = windArrow(cc.winddir16Point) + " " + cc.windspeedKmph + " km/h";
          weatherEl.innerHTML = '<div>' + (loc ? loc + "  " : "") + emoji + " " + desc + '</div>' +
            '<div>🌡️ ' + cc.temp_C + '°C</div>' +
            '<div>💧 ' + cc.humidity + '%  ·  🌀 ' + wind + '</div>';
        })
        .catch(function() { weatherEl.textContent = "☁️ --.-°C"; });
    }
    var savedCity = localStorage.getItem("weather-city");
    if (savedCity) {
      fetchWeather("https://wttr.in/" + encodeURIComponent(savedCity) + "?format=j1&lang=zh");
    } else if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        function(pos) {
          // Round to 1 decimal (~11km resolution) for city-level only
          var lat = Math.round(pos.coords.latitude * 10) / 10;
          var lng = Math.round(pos.coords.longitude * 10) / 10;
          fetchWeather("https://wttr.in/" + lat + "," + lng + "?format=j1&lang=zh");
          localStorage.setItem("weather-city", lat + "," + lng);
        },
        function() { fetchWeather("https://wttr.in/?format=j1&lang=zh"); },
        { timeout: 8000, enableHighAccuracy: true }
      );
    } else {
      fetchWeather("https://wttr.in/?format=j1&lang=zh");
    }
  }

  function handleCommand(cmd) {
    // Clear grep results when running any command
    if (grepResults) grepResults.classList.remove("show");
    const parts = cmd.trim().split(/\s+/);
    const name = parts[0].toLowerCase();

    if (!name) return;

    if (name === "cat") {
      const slug = parts.slice(1).join(" ");
      if (!slug) {
        showToast("Usage: cat <slug>");
        return;
      }
      if (slug.includes("/")) {
        showToast("cat: " + slug + ": No such file");
        return;
      }
      window.location.href = "/blog/" + slug;
    } else if (name === "activity") {
      window.location.href = "/activity";
    } else if (name === "archive") {
      window.location.href = "/archive";
    } else if (name === "weather") {
      var wcity = parts.slice(1).join(" ");
      if (wcity) {
        localStorage.setItem("weather-city", wcity);
        window.location.reload();
      } else {
        var cur = localStorage.getItem("weather-city");
        showToast(cur ? "weather: " + cur + " (type 'weather <city>' to change)" : "weather: auto (type 'weather <city>' to set)");
      }
    } else if (name === "theme") {
      var tname = parts.slice(1).join(" ");
      var themes = ["terminal","catppuccin","matrix","nord","gruvbox"];
      if (!tname) {
        showToast("theme: " + (localStorage.getItem("theme") || "terminal") + " (" + themes.join("/") + ")");
      } else if (themes.indexOf(tname) !== -1) {
        document.documentElement.setAttribute("data-theme", tname);
        localStorage.setItem("theme", tname);
        themeSelect.value = tname;
        showToast("theme set to " + tname);
      } else {
        showToast("theme: unknown theme \"" + tname + "\" (" + themes.join("/") + ")");
      }
    } else if (name === "travel") {
      window.location.href = "/travel";
    } else if (name === "downloads") {
      window.location.href = "/downloads";
    } else if (name === "scripts") {
      window.location.href = "/scripts";
    } else if (name === "ls") {
      window.location.href = "/blog";
    } else if (name === "whoami") {
      window.location.href = "/about";
    } else if (name === "get") {
      const script = parts.slice(1).join(" ");
      if (!script) {
        window.location.href = "/scripts";
      } else {
        window.location.href = `/scripts/${script}`;
      }
    } else if (name === "help") {
      showToast("cat <slug> | cd <path> | tag <name> | grep <query> | series | activity | archive | fortune | clear");
    } else if (name === "clear") {
      window.location.reload();
    } else if (name === "date") {
      const now = new Date();
      showToast(now.toLocaleString("zh-CN", { timeZone: "Asia/Shanghai" }));
    } else if (name === "series") {
      const s = parts.slice(1).join(" ");
      if (!s) {
        window.location.href = "/series";
      } else {
        window.location.href = "/series/" + s;
      }
    } else if (name === "tag") {
      const tag = parts.slice(1).join(" ");
      if (!tag) {
        window.location.href = "/tags";
      } else {
        window.location.href = `/tags/${tag}`;
      }
    } else if (name === "cd") {
      const knownPaths = ["/", "/home", "/blog", "/tags", "/travel", "/activity", "/archive", "/search", "/scripts", "/downloads", "/about"];
      const knownPrefixes = ["/tags/", "/blog/", "/scripts/"];
      const target = parts.slice(1).join(" ");
      let path;
      if (!target || target === "/" || target === "~" || target === "home") {
        path = "/";
      } else if (target === "..") {
        const current = window.location.pathname.replace(/\/$/, "");
        path = current.substring(0, current.lastIndexOf("/")) || "/";
      } else {
        path = target.startsWith("/") ? target : "/" + target;
      }
      path = path.replace(/\/$/, "") || "/";
      const valid = knownPaths.includes(path) || knownPrefixes.some(function(p) { return path.startsWith(p); });
      if (valid) {
        window.location.href = path;
      } else {
        showToast("cd: " + path + ": No such directory");
      }
    } else if (name === "grep") {
      const q = parts.slice(1).join(" ");
      if (!q) { showToast("Usage: grep <query>"); return; }
      showGrepResults(q);
    } else if (name === "fortune") {
      const qs = JSON.parse(document.getElementById("fortune-data").textContent);
      const q = qs[Math.floor(Math.random() * qs.length)];
      showToast('"' + q.text + '"' + (q.author ? " — " + q.author : ""));
    } else if (name === "zen") {
      var on = document.documentElement.getAttribute("data-zen") !== "true";
      document.documentElement.setAttribute("data-zen", on ? "true" : "false");
      localStorage.setItem("zen", on ? "true" : "false");
      showToast(on ? "zen mode on" : "zen mode off");
    } else if (name === "uptime") {
      var start = new Date(document.getElementById("uptime-data").getAttribute("data-start"));
      var now = new Date();
      var diff = Math.floor((now.getTime() - start.getTime()) / 1000);
      var days = Math.floor(diff / 86400);
      var hours = Math.floor((diff % 86400) / 3600);
      var mins = Math.floor((diff % 3600) / 60);
      showToast("uptime: " + days + " days, " + hours + " hours, " + mins + " mins");
    } else if (name === "tip") {
      var tips = [
        "Use '!!' to re-run the last command: sudo !!",
        "Press Ctrl+R to search command history",
        "Use 'cd -' to go back to the previous directory",
        "'cat file | less' — scroll through long output",
        "Use 'du -sh *' to see disk usage per item",
        "Wildcard tip: 'rm -rf *' won't delete hidden files (.xxx)",
        "Use 'history | grep foo' to find past commands",
        "Kill a process by name: pkill firefox",
        "'watch -n 1 command' — run command every second",
        "Use 'tree' to visualize directory structure",
        "'df -h' shows disk usage in human-readable format",
        "'free -h' shows memory usage",
        "Add '&' at end of command to run in background",
        "Use 'ncdu' for interactive disk usage analysis",
        "'Ctrl+Z' suspends a process, 'bg' sends it to background",
        "'!!:0' gets just the command name of last command",
        "'ssh-copy-id user@host' copies your SSH key",
        "Use 'tar -xvf file.tar.gz' to extract tarballs",
        "'curl ifconfig.me' shows your public IP",
        "'echo $?' shows exit code of last command (0 = success)",
        "Use 'which command' to find where a program is installed",
        "'chmod +x file' makes a file executable",
        "Use 'file filename' to check what type of file it is",
        "'head -n 20 file' shows first 20 lines, 'tail -n 20' last 20",
        "Use 'diff file1 file2' to compare two files",
        "'sort file | uniq -c' counts unique lines",
        "Use 'grep -r pattern .' to recursively search all files",
        "Combine commands with '&&': cmd1 && cmd2 (run if prev succeeds)",
        "'cmd1 | tee file' shows output AND saves to file",
        "Use 'alias ll=\"ls -la\"' to create shortcuts",
        "'Ctrl+W' deletes the word before cursor in terminal",
        "'Ctrl+U' clears the entire current line",
        "'Ctrl+A' jumps to start of line, 'Ctrl+E' to end",
        "Use 'ls -laS' to sort files by size",
        "'ls -latr' lists files by date (oldest last)",
        "Use 'find . -name \"*.txt\"' to find all txt files",
        "'grep -c pattern file' counts matches instead of displaying",
        "Use 'scp file user@host:/path/' to copy files over SSH",
        "'rsync -av source/ dest/' syncs directories efficiently",
        "Use 'journalctl -xe' to check system logs",
        "'systemctl status service' checks if a service is running",
        "Use 'htop' for interactive process management",
        "'lsof -i :8080' shows what's listening on port 8080",
        "Use 'ping -c 4 host' to send exactly 4 pings",
        "'nslookup domain.com' or 'dig domain.com' for DNS lookup",
        "Use 'cal' to display a calendar in terminal",
        "'date +%Y-%m-%d' outputs date in YYYY-MM-DD format",
        "Use 'time command' to measure how long a command takes",
        "'mkpasswd -m sha-512' generates a secure password hash",
        "Use 'openssl rand -base64 32' to generate a random key",
        "'Ctrl+L' clears the screen (same as 'clear')",
        "Use 'last' to see recent login history",
        "'w' or 'who' shows who's logged in",
        "Use 'id' to see your user and group IDs",
        "'uname -a' shows all system info",
        "Use 'lsblk' to list all block devices",
        "'blkid' shows UUID of disk partitions",
        "Use 'mtr host' combines ping + traceroute",
        "'ss -tuln' shows listening ports",
        "Use 'ip a' to see network interfaces (replaces ifconfig)",
      ];
      showToast(tips[Math.floor(Math.random() * tips.length)]);
    } else if (name === "night") {
      var on = document.documentElement.getAttribute("data-night") !== "true";
      document.documentElement.setAttribute("data-night", on ? "true" : "false");
      localStorage.setItem("night", on ? "true" : "false");
      showToast(on ? "night mode on" : "night mode off");
    } else if (name === "focus") {
      var on = document.documentElement.getAttribute("data-focus") !== "true";
      document.documentElement.setAttribute("data-focus", on ? "true" : "false");
      localStorage.setItem("focus", on ? "true" : "false");
      showToast(on ? "focus mode on (hover to reveal)" : "focus mode off");
    } else if (name === "rand") {
      var slugs = JSON.parse(document.getElementById("completion-data").textContent).slugs;
      if (slugs.length > 0) window.location.href = "/blog/" + slugs[Math.floor(Math.random() * slugs.length)];
    } else if (name === "matrix") {
      if (window.matrixRain) {
        window.matrixRain.toggle();
        showToast(window.matrixRain.isOn() ? "matrix rain on" : "matrix rain off");
      } else {
        window.location.href = "/";
      }
    } else if (name === "save") {
      var dl = document.querySelector("a[download]");
      if (dl) { dl.click(); showToast("saved"); }
      else {
        var text = document.title + "\n" + "-".repeat(document.title.length) + "\nURL: " + window.location.href + "\n\n" + (document.body.textContent || "").slice(0, 5000);
        var blob = new Blob([text], { type: "text/plain" });
        var a = document.createElement("a");
        a.href = URL.createObjectURL(blob);
        a.download = "page.txt";
        a.click();
        URL.revokeObjectURL(a.href);
        showToast("page saved");
      }
    } else {
      showToast(`command not found: ${name}. Type 'help'`);
    }
  }

  var commands_list = ["cat","ls","cd","whoami","date","clear","help","tag","get","scripts","downloads","travel","activity","archive","home","zen","fortune","series","grep","weather","theme","uptime","tip","matrix","save","night","focus","rand"];
  var suggestions = document.getElementById("cmd-suggestions");

  var tabMatches = [];
  var tabIndex = -1;
  var tabPartial = "";
  var tabIsCmd = false;

  function showSuggestions(items) {
    tabMatches = items;
    var html = "";
    for (var i = 0; i < items.length; i++) {
      html += '<span class="sug-item" data-idx="' + i + '">' + items[i] + "</span>";
      if (i < items.length - 1) html += "  ";
    }
    suggestions.innerHTML = html;
    suggestions.classList.add("show");
  }
  function hideSuggestions() {
    suggestions.classList.remove("show");
    tabMatches = [];
    tabIndex = -1;
    tabIsCmd = false;
  }
  function highlightSug(idx) {
    var items = suggestions.querySelectorAll(".sug-item");
    items.forEach(function(el, i) {
      el.style.color = i === idx ? "var(--green)" : "";
      el.style.textDecoration = i === idx ? "underline" : "";
    });
  }

  var compData = JSON.parse(document.getElementById("completion-data").textContent);
  var argMap = {
    cat: compData.slugs, tag: compData.tags, series: compData.series,
    get: compData.scripts,     cd: ["blog","tags","travel","activity","archive","search","scripts","downloads","about","home"],
    grep: null,
  };

  // Inline grep
  var grepResults = document.getElementById("grep-results");
  var searchIndex = JSON.parse(document.getElementById("search-index").textContent);

  function escHtml(s) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function showGrepResults(query) {
    var q = query.toLowerCase();
    var scored = searchIndex.map(function(p) {
      var title = p.title.toLowerCase();
      var desc = p.description.toLowerCase();
      var tags = p.tags.join(" ").toLowerCase();
      var content = p.content.toLowerCase();
      var s = 0;
      if (title === q) s += 100;
      if (title.includes(q)) s += 50;
      if (tags.includes(q)) s += 30;
      if (desc.includes(q)) s += 20;
      if (content.includes(q)) s += 10;
      return { post: p, score: s };
    }).filter(function(p) { return p.score > 0; }).sort(function(a, b) { return b.score - a.score; });

    if (scored.length === 0) {
      grepResults.innerHTML = '<div class="gr-stats">0 results for "' + escHtml(query) + '"</div>';
      grepResults.classList.add("show");
      return;
    }
    sessionStorage.setItem("grep-query", query);
    var html = '<div class="gr-stats">' + scored.length + ' result' + (scored.length !== 1 ? "s" : "") + ' for "' + escHtml(query) + '"</div>';
    var maxShow = Math.min(scored.length, 5);
    for (var i = 0; i < maxShow; i++) {
      var p = scored[i].post;
      html += '<a class="gr-item" href="/blog/' + p.slug + '">' +
        '<div class="gr-title">' + escHtml(p.title) + '</div>' +
        '<div class="gr-desc">' + p.date + (p.description ? " · " + escHtml(p.description) : "") + '</div>' +
        '</a>';
    }
    if (scored.length > 5) {
      html += '<div class="gr-stats" style="margin-top:0.3rem;">and <a href="/search?q=' + encodeURIComponent(query) + '" style="color:var(--green);">' + (scored.length - 5) + ' more on /search</a></div>';
    }
    grepResults.innerHTML = html;
    grepResults.classList.add("show");
  }

  document.addEventListener("keydown", function(e) {
    if (e.key === ":" && document.activeElement !== input && document.activeElement?.tagName !== "INPUT" && document.activeElement?.tagName !== "TEXTAREA" && document.activeElement?.getAttribute?.("contenteditable") !== "true") {
      e.preventDefault();
      input.focus();
      input.value = ":";
      input.setSelectionRange(1, 1);
    }
  });

  document.addEventListener("click", function(e) {
    if (grepResults && e.target.closest("#grep-results") === null) {
      grepResults.classList.remove("show");
    }
  });

  // Mobile Enter fix
  var cmdForm = document.getElementById("cmd-form");
  if (cmdForm) {
    cmdForm.addEventListener("submit", function(e) {
      e.preventDefault();
      hideSuggestions();
      if (grepResults) grepResults.classList.remove("show");
      handleCommand(input.value);
      input.value = "";
    });
  }

  input.addEventListener("keydown", function(e) {
    if (e.key === "Tab") {
      e.preventDefault();
      var val = input.value;
      var trimmed = val.trim();
      var parts = trimmed.split(/\s+/);
      var cmd = parts[0].toLowerCase();
      var completingCmd = (parts.length === 1 && !val.endsWith(" ")) || tabIsCmd;
      var matches;
      if (completingCmd) {
        if (!tabIsCmd) tabPartial = trimmed;
        matches = commands_list.filter(function(c) { return c.startsWith(tabIsCmd ? tabPartial : trimmed); });
      } else {
        var partial = tabMatches.length ? tabPartial : (parts[parts.length - 1] || "");
        var candidates = argMap[cmd];
        matches = candidates ? candidates.filter(function(c) { return c.startsWith(partial); }) : [];
      }
      if (matches.length === 1) {
        hideSuggestions(); tabMatches = []; tabPartial = ""; tabIndex = -1; tabIsCmd = false;
        input.value = completingCmd ? matches[0] + " " : val.replace(/\S+$/, "") + matches[0] + " ";
      } else if (matches.length > 1) {
        if (tabMatches.length === matches.length && tabMatches.every(function(v, i) { return v === matches[i]; })) {
          tabIndex = (tabIndex + 1) % matches.length;
        } else {
          tabMatches = matches;
          tabPartial = completingCmd ? trimmed : (parts[parts.length - 1] || "");
          tabIndex = 0;
          tabIsCmd = completingCmd;
        }
        input.value = completingCmd ? tabMatches[tabIndex] + " " : val.replace(/\S+$/, "") + tabMatches[tabIndex];
        showSuggestions(matches);
        highlightSug(tabIndex);
      } else {
        hideSuggestions();
      }
    } else if (e.key === "Escape") {
      hideSuggestions();
    } else if (e.key === "Enter") {
      hideSuggestions();
      handleCommand(input.value);
      input.value = "";
    } else {
      hideSuggestions();
      if (grepResults) grepResults.classList.remove("show");
    }
  });

  document.addEventListener("click", function(e) {
    hideSuggestions();
    if (e.target.tagName !== "A" && e.target.tagName !== "IMG" && e.target.tagName !== "INPUT" && e.target.tagName !== "TEXTAREA" && !window.getSelection().toString()) {
      input.focus();
    }
  });

  // Footer uptime
  var footerUptime = document.getElementById("footer-uptime");
  var uptimeStart = new Date(document.getElementById("uptime-data").getAttribute("data-start"));
  function updateUptime() {
    var diff = Math.floor((Date.now() - uptimeStart.getTime()) / 1000);
    var d = Math.floor(diff / 86400);
    var h = Math.floor((diff % 86400) / 3600);
    var m = Math.floor((diff % 3600) / 60);
    footerUptime.textContent = d + " days, " + h + " hours";
  }
  updateUptime();
  setInterval(updateUptime, 60000);

  // Back to top
  var topBtn = document.getElementById("back-to-top");
  if (topBtn) {
    window.addEventListener("scroll", function() {
      topBtn.classList.toggle("show", window.scrollY > 300);
    });
    topBtn.addEventListener("click", function() {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }

  // Theme switcher
  const themeSelect = document.getElementById("theme-select");
  themeSelect.value = localStorage.getItem("theme") || "terminal";
  themeSelect.addEventListener("change", () => {
    const theme = themeSelect.value;
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem("theme", theme);
  });
</script>
