---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Pagination from "../../../components/Pagination.astro";
import { statSync } from "fs";
import { join } from "path";

function fmtSize(bytes) {
  if (bytes < 1024) return bytes + "B";
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + "K";
  return (bytes / (1024 * 1024)).toFixed(1) + "M";
}

export async function getStaticPaths() {
  const PAGE_SIZE = 5;
  const all = await getCollection("blog");
  const visible = all.filter(p => !p.data.password);
  const sorted = visible
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .sort((a, b) => (b.data.pinned ? 1 : 0) - (a.data.pinned ? 1 : 0));
  const totalPages = Math.max(1, Math.ceil(sorted.length / PAGE_SIZE));
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
    props: { pageNum: i + 2, totalPages },
  }));
}

const PAGE_SIZE = 5;
const { pageNum, totalPages } = Astro.props;
const all = await getCollection("blog");
const visible = all.filter(p => !p.data.password);
const sorted = visible
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .sort((a, b) => (b.data.pinned ? 1 : 0) - (a.data.pinned ? 1 : 0));
const posts = sorted.slice((pageNum - 1) * PAGE_SIZE, pageNum * PAGE_SIZE);
---

<Layout title={`blog — page ${pageNum}`}>
  <div style="margin-bottom: 0.5rem;">
    <span style="color: var(--green);">[guest@brownlu-blog]</span>
    <span style="color: var(--dim);"> ~ $ </span>
    <span>ls -la /blog (page {pageNum}/{totalPages})</span>
  </div>

  <p style="margin-bottom: 1rem; color: var(--dim);">total {sorted.length}</p>

  <ul class="post-list">
    {posts.map((post) => {
      const date = post.data.date.toISOString().slice(0, 10);
      return (
        <li class="post-item">
          {post.data.image
            ? <img src={post.data.image} alt="" style="width:36px;height:36px;border-radius:4px;object-fit:cover;flex-shrink:0;border:1px solid var(--border);" />
            : <span style="width:36px;height:36px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1.2rem;">{post.data.password ? "🔒" : "📄"}</span>
          }
          <span style={post.data.pinned ? "color:var(--yellow);font-size:0.65rem;white-space:nowrap;" : "color:var(--dim);font-size:0.65rem;white-space:nowrap;"}>{post.data.pinned ? "drwxr-xr-x" : "-rw-r--r--"} 1 guest guest {(function(){try{return fmtSize(statSync(join(process.cwd(),"src/content/blog",post.id)).size).padStart(7)}catch(_){return "1.2K".padStart(7)}})()}</span>
          <a class="post-title" href={`/blog/${post.slug}`} style={post.data.pinned ? "color:var(--yellow);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" : "overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"}>
            {post.data.title}
          </a>
          {post.data.pinned && <span style="color: var(--yellow); font-size: 0.75rem; flex-shrink:0;">[Pinned]</span>}
          <span class="post-date" style="margin-left: auto;flex-shrink:0;">{date}</span>
        </li>
      );
    })}
  </ul>

  <Pagination currentPage={pageNum} totalPages={totalPages} base="/blog/page" />
</Layout>
