---
import { readFileSync } from "fs";
import { join } from "path";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { readingTime } from "../../utils/readingTime";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection("blog");
let seriesPrev, seriesNext;
if (post.data.series) {
  const sameSeries = allPosts
    .filter((p) => p.data.series === post.data.series)
    .sort((a, b) => (a.data.seriesOrder ?? 99) - (b.data.seriesOrder ?? 99));
  const idx = sameSeries.findIndex((p) => p.slug === post.slug);
  if (idx > 0) seriesPrev = sameSeries[idx - 1];
  if (idx >= 0 && idx < sameSeries.length - 1) seriesNext = sameSeries[idx + 1];
}
const rawMd = readFileSync(join(process.cwd(), "src/content/blog", post.id), "utf-8");
const downloadUri = "data:text/markdown;charset=utf-8," + encodeURIComponent(rawMd);

// Parse headings from markdown for server-side TOC (skip code blocks)
const headingLines = [];
let inCode = false;
for (const l of rawMd.split("\n")) {
  if (/^```/.test(l)) { inCode = !inCode; continue; }
  if (inCode) continue;
  const match = l.match(/^(#{1,3})\s+(.+)/);
  if (match) {
    headingLines.push({ level: match[1].length, text: match[2].replace(/[`*_~]/g, "").trim() });
  }
}
---

<Layout title={post.data.title}>
  <div style="margin-bottom: 0.5rem;">
    <span style="color: var(--green);">[guest@brownlu-blog]</span>
    <span style="color: var(--dim);"> ~ $ </span>
    <span>cat {post.slug}.md</span>
  </div>

  <nav class="toc" id="toc">
    <div style="color: var(--dim); font-size: 0.75rem; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;">Index</div>
    {headingLines.length > 0 && (
      <ul style="list-style:none;padding:0;margin:0;">
        {headingLines.map((h) => (
          <li style={{ 2: "padding-left:0", 3: "padding-left:1rem" }[h.level] || "padding-left:0"}>
            <a href={"#" + h.text.toLowerCase().replace(/\s+/g, "-").replace(/[^\w\u4e00-\u9fff-]/g, "")} style="color:var(--dim);text-decoration:none;display:block;font-size:0.8125rem;line-height:1.8;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
              {h.level === 3 && <span style="color:var(--dim);margin-right:0.25rem;">└─</span>}
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    )}
    {headingLines.length === 0 && <span style="color:var(--dim);font-size:0.75rem;">(no headings)</span>}
  </nav>
  <nav class="toc-mobile" id="toc-mobile">
    <button class="toc-toggle" id="toc-toggle" aria-label="Toggle table of contents">
      <span class="toc-indicator" id="toc-indicator">[+]</span>
      <span style="color:var(--dim);text-transform:uppercase;letter-spacing:0.05em;font-size:0.75rem;">Index</span>
      <span style="color:var(--dim);font-size:0.7rem;" id="toc-count">({headingLines.length})</span>
    </button>
    {headingLines.length > 0 && (
    <ul class="toc-list" id="toc-list" style="list-style:none;padding:0;margin:0.5rem 0 0 0;display:none;">
      {headingLines.map((h) => (
        <li style={{ 2: "padding-left:0.5rem", 3: "padding-left:1rem" }[h.level] || "padding-left:0"}>
          <a href={"#" + h.text.toLowerCase().replace(/\s+/g, "-").replace(/[^\w\u4e00-\u9fff-]/g, "")} style="color:var(--dim);text-decoration:none;display:block;font-size:0.8125rem;line-height:1.8;">
            {h.level === 2 && <span style="color:var(--dim);margin-right:0.25rem;">├─</span>}
            {h.level === 3 && <span style="color:var(--dim);margin-right:0.25rem;">└─</span>}
            {h.text}
          </a>
        </li>
      ))}
    </ul>
    )}
  </nav>
  <div style="margin-bottom: 1rem; color: var(--dim); font-size: 0.8125rem;" class="post-meta">
    <span>📖 {readingTime(rawMd)} min read</span>
    <span style="margin: 0 0.5rem;">·</span>
    <span>{rawMd.replace(/\s/g, "").length} chars</span>
    <span style="margin: 0 0.5rem;">·</span>
    <span>{post.data.date.toISOString().slice(0, 10)}</span>
  </div>
  {post.data.image && (
    <div style="margin-left:-1.5rem;margin-right:-1.5rem;position:relative;">
      <img src={post.data.image} alt={post.data.title} style="display:block;width:100%;max-height:320px;object-fit:cover;-webkit-mask-image:linear-gradient(to bottom,black 50%,transparent 100%);mask-image:linear-gradient(to bottom,black 50%,transparent 100%);" />
    </div>
  )}
  <div class="article-content" id="article-content" style={post.data.image ? "margin-top:-6rem;position:relative;z-index:1;" : ""}>
    <Content />
  </div>

  <div style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--border);">
    {post.data.tags && post.data.tags.length > 0 && (
      <div style="margin-bottom: 1rem;">
        <span style="color: var(--dim);">tags: </span>
        {post.data.tags.map((tag) => (
          <a href={`/tags/${tag}`} class="tag">{tag}</a>
        ))}
      </div>
    )}
    {post.data.series && (
      <div style="margin-bottom: 1rem; padding: 0.75rem; border: 1px solid var(--border); border-radius: 6px;">
        <div style="color: var(--yellow); font-size: 0.8125rem; margin-bottom: 0.5rem;">
          series: <a href={"/series/" + encodeURIComponent(post.data.series)} class="tag" style="font-size: 0.875rem;">{post.data.series}</a>
          {post.data.seriesOrder && <span style="color: var(--dim);"> — Part {post.data.seriesOrder}</span>}
        </div>
        <div style="display: flex; gap: 1rem; font-size: 0.8125rem;">
          {seriesPrev && <a href={"/blog/" + seriesPrev.slug} style="color: var(--green);">← {seriesPrev.data.title}</a>}
          {seriesNext && <a href={"/blog/" + seriesNext.slug} style="color: var(--green); margin-left: auto;">{seriesNext.data.title} →</a>}
        </div>
      </div>
    )}
    <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
      <a href="/blog" style="color: var(--green);">← back to /blog</a>
      <span style="color: var(--dim);">|</span>
      <a href={downloadUri} download={post.slug + ".md"} style="color: var(--yellow); font-size: 0.8125rem;">↓ download .md</a>
    </div>
  </div>
</Layout>

<style>
  .article-content { max-width: 100%; }
  .toc {
    display: none;
    position: fixed;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 160px;
    max-height: 70vh;
    overflow-y: auto;
    z-index: 100;
  }
  .toc a:hover { color: var(--green) !important; }
  @media (min-width: 1200px) { .toc { display: block; } }

  .toc-mobile {
    display: block;
    margin-bottom: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    background: var(--bg);
  }
  .toc-toggle {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    width: 100%;
    text-align: left;
    font-family: inherit;
    font-size: inherit;
    padding: 0.25rem 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .toc-toggle:hover .toc-indicator { color: var(--green); }
  .toc-mobile .toc-list a:hover { color: var(--green) !important; }
  @media (min-width: 1200px) { .toc-mobile { display: none; } }
</style>

<script>
// Toggle mobile TOC
var tocBtn = document.getElementById("toc-toggle");
var tocList = document.getElementById("toc-list");
var tocInd = document.getElementById("toc-indicator");
if (tocBtn && tocList) {
  tocBtn.addEventListener("click", function() {
    var expanded = tocList.style.display !== "none";
    tocList.style.display = expanded ? "none" : "block";
    tocInd.textContent = expanded ? "[+]" : "[-]";
  });
}

// Scroll spy for TOC (both desktop and mobile)
var links = document.querySelectorAll(".toc a, .toc-mobile a");
// Close mobile TOC on link click
links.forEach(function(a) {
  a.addEventListener("click", function() {
    if (tocList && window.innerWidth < 1200) {
      tocList.style.display = "none";
      tocInd.textContent = "[+]";
    }
  });
});
var headings = [];
links.forEach(function(a) {
  var id = a.getAttribute("href").slice(1);
  var el = document.getElementById(id) || document.querySelector("[id='" + id + "']");
  if (el) headings.push({ el: el, link: a });
});
function updateActive() {
  var scrollY = window.scrollY + 80;
  var active = null;
  headings.forEach(function(h) {
    if (h.el.offsetTop <= scrollY) active = h;
  });
  headings.forEach(function(h) {
    h.link.style.color = h === active ? "var(--green)" : "var(--dim)";
  });
}
window.addEventListener("scroll", updateActive);
updateActive();

// Reading progress bar
var bar = document.createElement("div");
bar.style.cssText = "position:fixed;top:0;left:0;height:2px;background:var(--green);z-index:1000;transition:width 0.1s;";
document.body.appendChild(bar);
window.addEventListener("scroll", function() {
  var h = document.documentElement.scrollHeight - window.innerHeight;
  bar.style.width = (h > 0 ? (window.scrollY / h) * 100 : 0) + "%";
});

// Copy button for code blocks
document.querySelectorAll(".article-content pre").forEach(function(pre) {
  var btn = document.createElement("button");
  btn.textContent = "copy";
  btn.style.cssText = "position:absolute;top:4px;right:4px;background:var(--bg);color:var(--green);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:var(--font-mono);font-size:0.75rem;cursor:pointer;opacity:0;transition:opacity 0.15s;";
  pre.style.position = "relative";
  pre.appendChild(btn);
  pre.addEventListener("mouseenter", function() { btn.style.opacity = "1"; });
  pre.addEventListener("mouseleave", function() { btn.style.opacity = "0"; });
  btn.addEventListener("click", function() {
    var code = pre.querySelector("code");
    navigator.clipboard.writeText(code ? code.textContent : pre.textContent).then(function() {
      btn.textContent = "done!";
      setTimeout(function() { btn.textContent = "copy"; }, 1500);
    });
  });
});
</script>
