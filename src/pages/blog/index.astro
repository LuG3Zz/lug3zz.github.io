---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Pagination from "../../components/Pagination.astro";
import BlogPostItem from "../../components/BlogPostItem.astro";

const PAGE_SIZE = 5;

const all = await getCollection("blog");
const visible = all.filter(p => !p.data.password);
const sorted = visible
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .sort((a, b) => (b.data.pinned ? 1 : 0) - (a.data.pinned ? 1 : 0));

const totalPages = Math.max(1, Math.ceil(sorted.length / PAGE_SIZE));
const posts = sorted.slice(0, PAGE_SIZE);
const currentPage = 1;
---

<Layout title="blog">
  <div style="margin-bottom: 0.5rem;">
    <span style="color: var(--green);">[guest@brownlu-blog]</span>
    <span style="color: var(--dim);"> ~ $ </span>
    <span>ls -la /blog</span>
  </div>

  <p style="margin-bottom: 1rem; color: var(--dim);">total {sorted.length}</p>

  <ul class="post-list">
    {posts.map((post) => <BlogPostItem {post} />)}
  </ul>

  <div style="margin-top: 1rem;">
    <Pagination currentPage={currentPage} totalPages={totalPages} base="/blog/page" />
  </div>

  <div style="margin-top: 0.75rem;">
    <a href="/tags" class="tag" style="font-size: 0.875rem;">→ browse by tags (/tags)</a>
    <span style="color: var(--dim); margin: 0 0.5rem;">|</span>
    <a href="/archive" class="tag" style="font-size: 0.875rem;">→ archive (/archive)</a>
  </div>
</Layout>
