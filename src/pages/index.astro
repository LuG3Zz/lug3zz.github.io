---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const posts = await getCollection("blog");
const sorted = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const siteName = "brownlu-blog";
const tagline = "a terminal-themed blog";
---

<Layout title={siteName}>
  <div style="margin-bottom: 0.5rem;">
    <span style="color: var(--green);">[guest@brownlu-blog]</span>
    <span style="color: var(--dim);"> ~ $ </span>
    <span>./welcome.sh --greet</span>
  </div>
  <p style="color: var(--yellow); margin-bottom: 1.5rem;">
    Welcome to <strong>{siteName}</strong> — {tagline}
  </p>

  <div style="margin-bottom: 0.5rem;">
    <span style="color: var(--green);">[guest@brownlu-blog]</span>
    <span style="color: var(--dim);"> ~ $ </span>
    <span>help --show-commands</span>
  </div>
  <div style="font-size: 0.875rem; margin-bottom: 1.5rem; line-height: 1.8;">
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  help</span><span style="color: var(--dim);">— show available commands</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  ls</span><span style="color: var(--dim);">— list blog posts</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  cat &lt;slug&gt;</span><span style="color: var(--dim);">— read a post</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  cd &lt;path&gt;</span><span style="color: var(--dim);">— navigate</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  whoami</span><span style="color: var(--dim);">— about me</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  date</span><span style="color: var(--dim);">— current time</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  activity</span><span style="color: var(--dim);">— post frequency heatmap</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  travel</span><span style="color: var(--dim);">— view travel map</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  downloads</span><span style="color: var(--dim);">— browse downloads</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  get &lt;script&gt;</span><span style="color: var(--dim);">— fetch a script</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  scripts</span><span style="color: var(--dim);">— list available scripts</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  tag &lt;name&gt;</span><span style="color: var(--dim);">— browse by tag</span></div>
  </div>

  <div style="margin-bottom: 0.5rem;">
    <span style="color: var(--green);">[guest@brownlu-blog]</span>
    <span style="color: var(--dim);"> ~ $ </span>
    <span>ls --latest --posts 5</span>
  </div>

  <h2 style="font-size: 1rem; margin: 0 0 0.75rem; color: var(--fg-bright);">
    ⚡ Latest Posts
  </h2>

  <ul class="post-list">
    {sorted.slice(0, 5).map((post) => (
      <li class="post-item">
        <a class="post-title" href={`/blog/${post.slug}`}>
          {post.data.title}
        </a>
        <span class="post-date" style="margin-left: auto;">
          {post.data.date.toISOString().slice(0, 10)}
        </span>
      </li>
    ))}
  </ul>

  <div style="margin-top: 1rem;">
    <a href="/blog" class="tag" style="font-size: 0.875rem;">→ view all posts (ls -la /blog)</a>
    <span style="color: var(--dim); margin: 0 0.5rem;">|</span>
    <a href="/tags" class="tag" style="font-size: 0.875rem;">→ browse by tags (/tags)</a>
  </div>
</Layout>
