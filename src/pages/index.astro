---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import BlogPostItem from "../components/BlogPostItem.astro";
import { quotes } from "../data/quotes";

const posts = (await getCollection("blog")).filter(p => !p.data.draft);
const visible = posts.filter(p => !p.data.password);
const sorted = visible
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .sort((a, b) => (b.data.pinned ? 1 : 0) - (a.data.pinned ? 1 : 0));

const siteName = "brownlu-blog";
const tagline = "a terminal-themed blog";
const fortune = quotes[Math.floor(Math.random() * quotes.length)];

const cmdStyle = "color:var(--fg-bright);";
const dimStyle = "color:var(--dim);";
const greenStyle = "color:var(--green);";
const yellowStyle = "color:var(--yellow);";
const blueStyle = "color:var(--blue);";
const sepStyle = "border-top:1px dashed var(--border);margin:1.75rem 0;";
const promptUser = "guest";
---

<Layout title={siteName}>
  <div style="margin-bottom:0.5rem;">
    <span style="color:var(--green);">┌──(</span><span class="prompt-user-display" style="color:var(--yellow);">guest</span><span style="color:var(--dim);">@</span><span style="color:var(--blue);">brownlu-blog</span><span style="color:var(--green);">)</span><span style="color:var(--dim);"> ~$ </span>
    <span style={cmdStyle}>./welcome.sh --greet</span>
  </div>
  <pre id="welcome-output" style="color:var(--yellow);margin:0 0 1.5rem 0;line-height:1.4;white-space:pre-wrap;background:none;border:none;padding:0;font-family:inherit;"></pre>

  <details class="help-section" id="help-section">
    <summary style="margin-bottom:0.5rem;cursor:pointer;list-style:none;display:flex;align-items:center;gap:0.5rem;">
      <span style="color:var(--green);">┌──(</span><span class="prompt-user-display" style="color:var(--yellow);">guest</span><span style="color:var(--dim);">@</span><span style="color:var(--blue);">brownlu-blog</span><span style="color:var(--green);">)</span><span style="color:var(--dim);"> ~$ </span>
      <span style={cmdStyle}>help --show-commands</span>
      <span id="help-toggle" style="color:var(--dim);font-size:0.75rem;margin-left:auto;">[+]</span>
    </summary>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.25rem 1rem;font-size:0.8125rem;margin-bottom:1.5rem;line-height:1.9;padding:0.25rem 0 0.25rem 0.5rem;border-left:2px solid var(--border);">
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  help</span><span style="color:var(--dim);">— show commands</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  cat &lt;slug&gt;</span><span style="color:var(--dim);">— read a post</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  ls</span><span style="color:var(--dim);">— list posts</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  cd &lt;path&gt;</span><span style="color:var(--dim);">— navigate</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  grep &lt;query&gt;</span><span style="color:var(--dim);">— search posts</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  tag &lt;name&gt;</span><span style="color:var(--dim);">— browse tag</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  series</span><span style="color:var(--dim);">— browse series</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  rand</span><span style="color:var(--dim);">— random post</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  login</span><span style="color:var(--dim);">— sync Gist data</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  profile</span><span style="color:var(--dim);">— avatar / bio</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  todo</span><span style="color:var(--dim);">— task manager</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  pomo &lt;min&gt;</span><span style="color:var(--dim);">— pomodoro timer</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  music &lt;kwd&gt;</span><span style="color:var(--dim);">— play music</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  weather &lt;city&gt;</span><span style="color:var(--dim);">— forecast</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  theme &lt;name&gt;</span><span style="color:var(--dim);">— switch theme</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  fortune</span><span style="color:var(--dim);">— random quote</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  activity</span><span style="color:var(--dim);">— stats & charts</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  archive</span><span style="color:var(--dim);">— year/month</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  travel</span><span style="color:var(--dim);">— travel map</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  dashboard</span><span style="color:var(--dim);">— personal stats</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  culture</span><span style="color:var(--dim);">— mood / habit / post</span></div>
      <div><span style="color:var(--yellow);min-width:10rem;display:inline-block;">  zen / focus / night</span><span style="color:var(--dim);">— display modes</span></div>
    </div>
  </details>

  <div style={sepStyle}></div>

  <div style="margin-bottom:1rem;">
    <span style="color:var(--green);">┌──(</span><span class="prompt-user-display" style="color:var(--yellow);">guest</span><span style="color:var(--dim);">@</span><span style="color:var(--blue);">brownlu-blog</span><span style="color:var(--green);">)</span><span style="color:var(--dim);"> ~$ </span>
    <span style={cmdStyle}>ls --latest --posts 5</span>
  </div>

  <h2 style="font-size:0.9rem;margin:0 0 0.75rem 0.5rem;color:var(--fg-bright);display:flex;align-items:center;gap:0.4rem;">
    <span style="color:var(--green);">◆</span> Latest Posts
  </h2>

  <ul class="post-list">
    {sorted.slice(0, 5).map((post) => <BlogPostItem {post} showMeta={false} />)}
  </ul>

  <div style="margin-top:1rem;display:flex;gap:0.75rem;flex-wrap:wrap;padding-left:0.5rem;">
    <a href="/blog" class="tag" style="font-size:0.8125rem;">→ view all (ls -la /blog)</a>
    <span style="color:var(--dim);">|</span>
    <a href="/tags" class="tag" style="font-size:0.8125rem;">→ browse by tags (/tags)</a>
  </div>

  <div style={sepStyle}></div>

  <div class="fortune-box" id="fortune-box" style="margin-top:0.5rem;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:6px;border-left:3px solid var(--green);">
    <div style="color:var(--dim);font-size:0.75rem;margin-bottom:0.35rem;display:flex;align-items:center;gap:0.4rem;">
      <span style="color:var(--green);font-size:0.6rem;">◆</span> $ fortune
    </div>
    <div style="padding-left:0.3rem;">
      <span style="color:var(--fg);font-size:0.875rem;font-style:italic;">"{fortune.text}"</span>
      {fortune.author && <span style="color:var(--dim);font-size:0.8125rem;"> — <span style="color:var(--cyan);">{fortune.author}</span></span>}
    </div>
  </div>
</Layout>
</Layout>

<script define:vars={{ siteName, tagline }}>
var user = localStorage.getItem("logged-in") === "true" ? "root" : "guest";
document.querySelectorAll(".prompt-user-display").forEach(function(el) { el.textContent = user; });
var el = document.getElementById("welcome-output");
var cursor = '<span class="cursor-block" style="display:inline-block;"></span>';

var cow = "  \\   ^__^\n" +
  "   \\  (oo)\\_______\n" +
  "      (__)\\       )\\/\\\n" +
  "          ||----w |\n" +
  "          ||     ||";

var hr = new Date().getHours();
var greet = hr < 12 ? "Good morning" : hr < 18 ? "Good afternoon" : "Good evening";
var user = localStorage.getItem("logged-in") === "true" ? "root" : "guest";
var today = new Date().toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric", weekday: "long" });
var msg = greet + ", " + user + "! Today is " + today + ".";
var border = "+" + "-".repeat(msg.length + 2) + "+";
var bubble = border + "\n| " + msg + " |\n" + border;

var fullText = "Welcome to " + siteName + " — " + tagline + ".\n\n" + bubble + "\n" + cow;
var i = 0;
function type() {
  if (i < fullText.length) {
    var ch = fullText[i];
    var escaped = ch === "<" ? "&lt;" : ch === ">" ? "&gt;" : ch === "&" ? "&amp;" : ch;
    el.innerHTML = el.innerHTML.slice(0, -cursor.length) + escaped + cursor;
    i++;
    setTimeout(type, 20 + Math.random() * 20);
  } else {
    el.innerHTML = el.innerHTML.slice(0, -cursor.length);
  }
}
type();

const helpSection = document.getElementById("help-section");
const helpToggle = document.getElementById("help-toggle");
if (helpSection) {
  helpSection.addEventListener("toggle", function() {
    helpToggle.textContent = helpSection.open ? "[-]" : "[+]";
  });
}
</script>
