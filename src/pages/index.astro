---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { quotes } from "../data/quotes";

const posts = await getCollection("blog");
const sorted = posts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .sort((a, b) => (b.data.pinned ? 1 : 0) - (a.data.pinned ? 1 : 0));

const siteName = "brownlu-blog";
const tagline = "a terminal-themed blog";
const fortune = quotes[Math.floor(Math.random() * quotes.length)];
---

<Layout title={siteName}>
  <div style="margin-bottom: 0.5rem;">
    <span style="color: var(--green);">[guest@brownlu-blog]</span>
    <span style="color: var(--dim);"> ~ $ </span>
    <span>./welcome.sh --greet</span>
  </div>
  <pre id="welcome-output" style="color: var(--yellow); margin: 0 0 1.5rem 0; line-height: 1.4; white-space: pre-wrap; background: none; border: none; padding: 0; font-family: inherit;"></pre>

  <details class="help-section" id="help-section">
    <summary style="margin-bottom: 0.5rem; cursor: pointer; list-style: none; display: flex; align-items: center; gap: 0.5rem;">
      <span style="color: var(--green);">[guest@brownlu-blog]</span>
      <span style="color: var(--dim);"> ~ $ </span>
      <span>help --show-commands</span>
      <span id="help-toggle" style="color: var(--dim); font-size: 0.75rem; margin-left: auto;">[+]</span>
    </summary>
    <div style="font-size: 0.875rem; margin-bottom: 1.5rem; line-height: 1.8;">
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  help</span><span style="color: var(--dim);">— show available commands</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  ls</span><span style="color: var(--dim);">— list blog posts</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  cat &lt;slug&gt;</span><span style="color: var(--dim);">— read a post (Tab to autocomplete)</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  cd &lt;path&gt;</span><span style="color: var(--dim);">— navigate directories</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  grep &lt;query&gt;</span><span style="color: var(--dim);">— search posts inline</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  tag &lt;name&gt;</span><span style="color: var(--dim);">— browse by tag</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  series</span><span style="color: var(--dim);">— browse series</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  get &lt;script&gt;</span><span style="color: var(--dim);">— fetch a script</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  activity</span><span style="color: var(--dim);">— stats & heatmap</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  archive</span><span style="color: var(--dim);">— posts by year/month</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  travel</span><span style="color: var(--dim);">— view travel map</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  fortune</span><span style="color: var(--dim);">— random quote</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  zen</span><span style="color: var(--dim);">— distraction-free reading</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  whoami</span><span style="color: var(--dim);">— about me</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  date</span><span style="color: var(--dim);">— current time</span></div>
    <div><span style="color: var(--yellow); min-width: 12rem; display: inline-block;">  clear</span><span style="color: var(--dim);">— refresh page</span></div>
  </div></details>

  <div style="margin-bottom: 0.5rem;">
    <span style="color: var(--green);">[guest@brownlu-blog]</span>
    <span style="color: var(--dim);"> ~ $ </span>
    <span>ls --latest --posts 5</span>
  </div>

  <h2 style="font-size: 1rem; margin: 0 0 0.75rem; color: var(--fg-bright);">
    ⚡ Latest Posts
  </h2>

  <ul class="post-list">
    {sorted.slice(0, 5).map((post) => (
      <li class="post-item">
        {post.data.image
          ? <img src={post.data.image} alt="" style="width:36px;height:36px;border-radius:4px;object-fit:cover;flex-shrink:0;border:1px solid var(--border);" />
          : <span style="width:36px;height:36px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1.2rem;">📄</span>
        }
        <a class="post-title" href={`/blog/${post.slug}`}>
          {post.data.title}
        </a>
        {post.data.pinned && <span style="color: var(--yellow); font-size: 0.75rem; margin-left: 0.5rem;">[Pinned]</span>}
        <span class="post-date" style="margin-left: auto;">
          {post.data.date.toISOString().slice(0, 10)}
        </span>
      </li>
    ))}
  </ul>

  <div style="margin-top: 1rem;">
    <a href="/blog" class="tag" style="font-size: 0.875rem;">→ view all posts (ls -la /blog)</a>
    <span style="color: var(--dim); margin: 0 0.5rem;">|</span>
    <a href="/tags" class="tag" style="font-size: 0.875rem;">→ browse by tags (/tags)</a>
  </div>

  <div class="fortune-box" id="fortune-box" style="margin-top: 2rem; padding: 1rem; border: 1px solid var(--border); border-radius: 6px;">
    <div style="color: var(--dim); font-size: 0.75rem; margin-bottom: 0.25rem;">$ fortune</div>
    <div style="color: var(--green); font-size: 0.875rem; font-style: italic;">
      "{fortune.text}"{fortune.author ? <span style="color: var(--dim);"> — {fortune.author}</span> : ""}
    </div>
  </div>
</Layout>

<canvas id="matrix-canvas" style="position:fixed;top:0;left:0;width:100%;height:100%;z-index:-1;pointer-events:none;display:none;"></canvas>

<script define:vars={{ siteName, tagline }}>
var el = document.getElementById("welcome-output");
var cursor = '<span class="cursor-block" style="display:inline-block;"></span>';

var cow = "  \\   ^__^\n" +
  "   \\  (oo)\\_______\n" +
  "      (__)\\       )\\/\\\n" +
  "          ||----w |\n" +
  "          ||     ||";

var msg = "Hello, guest! Welcome to " + siteName + ".";
var border = "+" + "-".repeat(msg.length + 2) + "+";
var bubble = border + "\n| " + msg + " |\n" + border;

var fullText = "Welcome to " + siteName + " — " + tagline + ".\n\n" + bubble + "\n" + cow;
var i = 0;
function type() {
  if (i < fullText.length) {
    var ch = fullText[i];
    var escaped = ch === "<" ? "&lt;" : ch === ">" ? "&gt;" : ch === "&" ? "&amp;" : ch;
    el.innerHTML = el.innerHTML.slice(0, -cursor.length) + escaped + cursor;
    i++;
    setTimeout(type, 20 + Math.random() * 20);
  } else {
    el.innerHTML = el.innerHTML.slice(0, -cursor.length);
  }
}
type();

const helpSection = document.getElementById("help-section");
const helpToggle = document.getElementById("help-toggle");
if (helpSection) {
  helpSection.addEventListener("toggle", function() {
    helpToggle.textContent = helpSection.open ? "[-]" : "[+]";
  });
}

// Matrix rain
(function() {
  var canvas = document.getElementById("matrix-canvas");
  if (!canvas) return;
  var ctx = canvas.getContext("2d");
  var drops, columns, fontSize = 14;

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    columns = Math.floor(canvas.width / fontSize);
    drops = [];
    for (var i = 0; i < columns; i++) drops[i] = Math.random() * -canvas.height / fontSize;
  }
  resize();
  var isMobile = window.innerWidth < 768;
  var intervalTime = isMobile ? 80 : 50;
  var rt;
  window.addEventListener("resize", function() { clearTimeout(rt); rt = setTimeout(resize, 200); });

  var chars = "0123456789ABCDEF0123456789";
  function draw() {
    ctx.fillStyle = "rgba(13,13,13,0.05)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = "#33ff33";
    ctx.font = fontSize + "px monospace";
    for (var i = 0; i < drops.length; i++) {
      var text = chars[Math.floor(Math.random() * chars.length)];
      ctx.fillText(text, i * fontSize, drops[i] * fontSize);
      if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
      drops[i]++;
    }
  }
  var interval;
  function start() {
    if (interval) return;
    canvas.style.display = "block";
    interval = setInterval(draw, intervalTime);
  }
  function stop() {
    if (interval) { clearInterval(interval); interval = null; }
    canvas.style.display = "none";
  }
  function toggle() {
    if (interval) { stop(); localStorage.setItem("matrix-rain", "false"); }
    else { start(); localStorage.setItem("matrix-rain", "true"); }
  }
  if (localStorage.getItem("matrix-rain") === "true") start();
  window.matrixRain = { toggle: toggle, start: start, stop: stop, isOn: function() { return !!interval; } };
})();
</script>
