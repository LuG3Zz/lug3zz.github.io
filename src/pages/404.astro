---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404">
  <div style="margin-bottom: 0.5rem;">
    <span style="color: var(--green);">[guest@brownlu-blog]</span>
    <span style="color: var(--dim);"> ~ $ </span>
    <span>curl -I {Astro.url.pathname}</span>
  </div>

  <pre style="background: none; border: none; padding: 0; font-size: 0.75rem; line-height: 1.3; color: var(--red); margin-bottom: 1.5rem;">
    __   __  _______  __   __  _______  __   __ 
   |  | |  ||       ||  | |  ||       ||  | |  |
   |  |_|  ||   _   ||  |_|  ||   _   ||  | |  |
   |       ||  | |  ||       ||  | |  ||  |_|  |
   |_     _||  |_|  ||       ||  |_|  ||       |
     |   |  |       ||   _   ||       ||       |
     |___|  |_______||__| |__||_______||_______|
  </pre>

  <p style="color: var(--dim); margin-bottom: 1rem;">
    HTTP/1.1 <span style="color: var(--red);">404 Not Found</span>
  </p>

  <p style="margin-bottom: 0.5rem;">
    The path <code style="color: var(--yellow);">{Astro.url.pathname}</code> does not exist on this server.
  </p>

  <p style="margin-bottom: 2rem; color: var(--dim);">
    Maybe you mistyped the URL, or the page has been moved.
  </p>

  <div style="border: 1px solid var(--border); border-radius: 6px; padding: 1rem;">
    <div style="color: var(--yellow); margin-bottom: 0.75rem;">$ ls /</div>
    <div style="display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.875rem;">
      <a href="/" style="color: var(--green);">  home</a>
      <a href="/blog" style="color: var(--green);">  blog</a>
      <a href="/tags" style="color: var(--green);">  tags</a>
      <a href="/about" style="color: var(--green);">  about</a>
    </div>
  </div>
</Layout>
