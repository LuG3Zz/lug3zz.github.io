---
import Layout from "../layouts/Layout.astro";
import { places } from "../data/travel";
---

<Layout title="travel">
  <link rel="stylesheet" href="/lib/leaflet/leaflet.css" />
  <div style="margin-bottom: 0.5rem;">
    <span style="color: var(--green);">[guest@brownlu-blog]</span>
    <span style="color: var(--dim);"> ~ $ </span>
    <span>cat /travel</span>
  </div>

  <div id="travel-map" style="height: 400px; border-radius: 6px; margin-bottom: 1.5rem;"></div>

  <p style="margin-bottom: 1rem; color: var(--dim);">{places.length} cities visited</p>

  <ul class="post-list">
    {places.map((p) => (
      <li class="post-item">
        <span class="post-title" style="font-size: 0.875rem;">📍 {p.city}</span>
        <span style="color: var(--fg); font-size: 0.8125rem;">{p.description}</span>
        <span class="post-date" style="margin-left: auto;">{p.date}</span>
      </li>
    ))}
  </ul>

  <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1rem;">
    {places.map((p) => {
      const imgs = p.images || (p.image ? [p.image] : []);
      return imgs.length > 0 && (
        <div style="border: 1px solid var(--border); border-radius: 6px; padding: 0.75rem; min-width: 200px; flex: 1;">
          <div style="color: var(--yellow); font-size: 0.8125rem; margin-bottom: 0.5rem;">📸 {p.city}</div>
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            {imgs.map((src) => (
              <img src={src} style="width:100%;border-radius:4px;border:1px solid var(--border);" loading="lazy" />
            ))}
          </div>
        </div>
      );
    })}
  </div>

  <div id="travel-data" data-places={JSON.stringify(places)} style="display:none"></div>
</Layout>

<script is:inline src="/lib/leaflet/leaflet.js"></script>
<script is:inline>
(function() {
  var el = document.getElementById("travel-data");
  if (!el) return;
  var data;
  try { data = JSON.parse(el.getAttribute("data-places")); } catch(e) { return; }
  if (!data || data.length === 0) return;

  var markerIcon = L.divIcon({
    className: "",
    html: '<div style="width:24px;height:24px;background:#1978c8;border-radius:50% 50% 50% 0;transform:rotate(-45deg);box-shadow:0 1px 4px rgba(0,0,0,0.4);"><div style="width:8px;height:8px;background:#fff;border-radius:50%;position:absolute;top:8px;left:8px;"></div></div>',
    iconSize: [24, 24],
    iconAnchor: [12, 24],
    popupAnchor: [0, -28],
  });

  var map = L.map("travel-map").setView([35, 110], 6);
  L.tileLayer("https://webrd01.is.autonavi.com/appmaptile?lang=zh_cn&size=1&scale=1&style=8&x={x}&y={y}&z={z}", {
    maxZoom: 18, attribution: "高德地图"
  }).addTo(map);

  var coords = [];
  for (var i = 0; i < data.length; i++) {
    var p = data[i];
    coords.push([p.lat, p.lng]);
    var imgs = (p.images || []).map(function(src) {
      return '<img src="' + src + '" style="max-width:200px;border-radius:4px;margin-top:4px;display:block;" loading="lazy" />';
    }).join("");
    var popup = "<strong>" + p.city + "</strong>" +
      (p.date ? "<br><span style='color:#999;font-size:0.85em;'>" + p.date + "</span>" : "") +
      (p.description ? "<br>" + p.description : "") +
      imgs;
    L.marker([p.lat, p.lng], { icon: markerIcon }).addTo(map).bindPopup(popup, { maxWidth: 260 });
  }
  if (coords.length > 1) map.fitBounds(coords, { padding: [50, 50] });
})();
</script>
