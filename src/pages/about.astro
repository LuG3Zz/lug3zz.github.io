---
import Layout from "../layouts/Layout.astro";
---

<Layout title="about">
  <div style="margin-bottom: 0.5rem;">
    <span style="color: var(--green);">[guest@terminal-blog]</span>
    <span style="color: var(--dim);"> ~ $ </span>
    <span>whoami</span>
  </div>

  <pre style="background: none; border: none; padding: 0; font-size: 0.75rem; line-height: 1.3; color: var(--green); margin-bottom: 1.5rem;">
      /\    /\
     /  \  /  \
    /    \/    \
   /            \
  /______________\
  |   .--.    |  |
  |  /    \   |  |
  |  |    |   |  |
  |  \__/    |  |
  |__________|__|
  </pre>

  <p>
    Hi, I'm <strong style="color: var(--fg-bright);">LuG3Zz</strong>.
    This is my terminal-themed corner of the internet.
  </p>

  <p>
    I built this blog with <a href="https://astro.build">Astro</a>,
    styled like a classic terminal emulator — because the command line
    is where the magic happens.
  </p>

  <p>Feel free to look around, read some posts, and enjoy your stay.</p>

  <div style="margin-top: 1.5rem; padding: 1rem; border: 1px solid var(--border); border-radius: 6px;">
    <div style="color: var(--yellow); margin-bottom: 0.5rem;">$ cat contact.txt</div>
    <div><span class="tag">github</span> <a href="https://github.com/LuG3Zz">LuG3Zz</a></div>
  </div>
</Layout>
