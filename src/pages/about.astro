---
import Layout from "../layouts/Layout.astro";
---

<Layout title="about">
  <div style="margin-bottom: 0.5rem;">
    <span style="color: var(--green);">[guest@brownlu-blog]</span>
    <span style="color: var(--dim);"> ~ $ </span>
    <span>whoami</span>
  </div>

  <pre style="background: none; border: none; padding: 0; margin-bottom: 1.5rem; line-height: 1.4; font-size: 0.75rem;">
<span style="color:var(--dim);">           .-------------------------:      </span><span style="color:var(--fg-bright);">brownlu@cachyos-x8664</span>
<span style="color:var(--dim);">          .+=========================.      </span><span style="color:var(--dim);">---------------------</span>
<span style="color:var(--yellow);">         :++===++==================-       :++-           </span><span style="color:var(--blue);">OS:</span><span style="color:var(--fg);"> CachyOS x86_64</span>
<span style="color:var(--yellow);">        :*++====+++++=============-        .==:           </span><span style="color:var(--blue);">Host:</span><span style="color:var(--fg);"> 20T1S81T00 (ThinkPad T14s Gen 1)</span>
<span style="color:var(--yellow);">       -*+++=====+***++==========:                        </span><span style="color:var(--blue);">Kernel:</span><span style="color:var(--fg);"> Linux 7.0.2-2-cachyos</span>
<span style="color:var(--yellow);">      =*++++========------------:                         </span><span style="color:var(--blue);">Uptime:</span><span style="color:var(--fg);"> 4 hours, 53 mins</span>
<span style="color:var(--green);">     =*+++++=====-                     ...                </span><span style="color:var(--blue);">Packages:</span><span style="color:var(--fg);"> 1163 (pacman)</span>
<span style="color:var(--green);">   .+*+++++=-===:                    .=+++=:              </span><span style="color:var(--blue);">Shell:</span><span style="color:var(--fg);"> fish 4.6.0</span>
<span style="color:var(--green);">  :++++=====-==:                     -*****+              </span><span style="color:var(--blue);">Display:</span><span style="color:var(--fg);"> 1920x1080 14" 60Hz</span>
<span style="color:var(--fg-bright);"> :++========-=.                      .=+**+.              </span><span style="color:var(--blue);">WM:</span><span style="color:var(--fg);"> mango (Wayland)</span>
<span style="color:var(--fg-bright);">.+==========-.                          .                 </span><span style="color:var(--blue);">Theme:</span><span style="color:var(--fg);"> adw-gtk3 [GTK3]</span>
<span style="color:var(--cyan);"> :+++++++====-                                .--==-.     </span><span style="color:var(--blue);">Font:</span><span style="color:var(--fg);"> Noto Sans 10pt [GTK3]</span>
<span style="color:var(--cyan);">  :++==========.                             :+++++++:    </span><span style="color:var(--blue);">Cursor:</span><span style="color:var(--fg);"> capitaine</span>
<span style="color:var(--cyan);">   .-===========.                            =*****+*+    </span><span style="color:var(--blue);">Terminal:</span><span style="color:var(--fg);"> ghostty 1.3.1</span>
<span style="color:var(--cyan);">    .-===========:                           .+*****+:    </span><span style="color:var(--blue);">Terminal Font:</span><span style="color:var(--fg);"> Maple Mono NF CN 12pt</span>
<span style="color:var(--dim);">      -=======++++:::::::::::::::::::::::::-:  .---:      </span><span style="color:var(--blue);">CPU:</span><span style="color:var(--fg);"> Intel i7-10510U (8) @ 4.90 GHz</span>
<span style="color:var(--dim);">       :======++++====+++******************=.             </span><span style="color:var(--blue);">GPU:</span><span style="color:var(--fg);"> Intel UHD Graphics</span>
<span style="color:var(--dim);">        :=====+++==========++++++++++++++*-               </span><span style="color:var(--blue);">Memory:</span><span style="color:var(--fg);"> 5.53 GiB / 15.40 GiB (36%)</span>
<span style="color:var(--dim);">         .====++==============++++++++++*-                </span><span style="color:var(--blue);">Disk:</span><span style="color:var(--fg);"> 46.20 GiB / 100.00 GiB (46%)</span>
<span style="color:var(--dim);">          .===+==================+++++++:                 </span><span style="color:var(--blue);">Battery:</span><span style="color:var(--fg);"> 84% [Discharging]</span>
<span style="color:var(--dim);">           .-=======================+++:                  </span><span style="color:var(--blue);">Locale:</span><span style="color:var(--fg);"> zh_CN.UTF-8</span>
<span style="color:var(--dim);">             ..........................
  </pre>

  <p style="margin-bottom: 1rem;">
    Hello. I'm <strong style="color: var(--fg-bright);">brownlu</strong> — a developer who
    believes the terminal is still the most honest interface.
  </p>

  <p style="margin-bottom: 1rem;">
    This blog is where I write about things I build, things I learn,
    and things I find interesting — mostly around web development,
    Linux, and open source.
  </p>

  <p style="margin-bottom: 1rem;">
    Built with <a href="https://astro.build">Astro</a>, styled for the
    command line. No JavaScript frameworks on the frontend, no tracking,
    no distractions. Just text and code, the way it should be.
  </p>

  <p style="margin-bottom: 1rem;">
    When I'm not typing into a terminal, I'm probably traveling,
    taking photos, or thinking about the next thing to build.
  </p>

  <div id="gh-activity" style="margin-top: 1.5rem; padding: 1rem; border: 1px solid var(--border); border-radius: 6px;">
    <div style="color: var(--yellow); margin-bottom: 0.5rem;">$ curl -s "https://api.github.com/users/LuG3Zz/events?per_page=5"</div>
    <div style="color: var(--dim); font-size: 0.8125rem;">loading...</div>
  </div>

  <div style="margin-top: 1.5rem; padding: 1rem; border: 1px solid var(--border); border-radius: 6px;">
    <div style="color: var(--yellow); margin-bottom: 0.5rem;">$ cat contact.txt</div>
    <div><span class="tag">github</span> <a href="https://github.com/LuG3Zz">LuG3Zz</a></div>
    <div><span class="tag">bilibili</span> <a href="https://space.bilibili.com/35391097">space.bilibili.com/35391097</a></div>
    <div><span class="tag">email</span> <a href="mailto:1403338195@qq.com">1403338195@qq.com</a></div>
    <div><span class="tag">site</span> <a href="https://lug3zz.github.io">lug3zz.github.io</a></div>
  </div>
</Layout>

<script>
(function() {
  var el = document.getElementById("gh-activity");
  if (!el) return;
  fetch("https://api.github.com/users/LuG3Zz/events?per_page=5")
    .then(function(r) { return r.json(); })
    .then(function(events) {
      if (!events || events.length === 0) { el.innerHTML = '<div style="color:var(--yellow);margin-bottom:0.5rem;">$ curl -s "https://api.github.com/users/LuG3Zz/events?per_page=5"</div><div style="color:var(--dim);font-size:0.8125rem;">no recent activity</div>'; return; }
      var typeIcons = { PushEvent: "📤", CreateEvent: "📦", IssuesEvent: "🐛", PullRequestEvent: "🔀", WatchEvent: "⭐", ForkEvent: "🍴", IssueCommentEvent: "💬", DeleteEvent: "🗑️" };
      var html = '<div style="color:var(--yellow);margin-bottom:0.5rem;">$ curl -s "https://api.github.com/users/LuG3Zz/events?per_page=5"</div>';
      for (var i = 0; i < Math.min(events.length, 5); i++) {
        var e = events[i];
        var icon = typeIcons[e.type] || "⚡";
        var repo = e.repo.name;
        var desc = "";
        if (e.type === "PushEvent") desc = (e.payload.commits || []).map(function(c) { return c.message.split("\n")[0]; }).join("; ");
        else if (e.type === "CreateEvent") desc = "created " + e.payload.ref_type + " " + (e.payload.ref || "");
        else if (e.type === "IssuesEvent") desc = e.payload.action + " issue: " + (e.payload.issue && e.payload.issue.title);
        else if (e.type === "PullRequestEvent") desc = e.payload.action + " PR: " + (e.payload.pull_request && e.payload.pull_request.title);
        else if (e.type === "WatchEvent") desc = "starred";
        else if (e.type === "ForkEvent") desc = "forked";
        var ago = Math.floor((Date.now() - new Date(e.created_at).getTime()) / 3600000);
        var timeStr = ago < 1 ? "just now" : ago < 24 ? ago + "h ago" : Math.floor(ago / 24) + "d ago";
        html += '<div style="margin-bottom:0.4rem;font-size:0.8125rem;">' +
          '<span style="color:var(--dim);">' + icon + ' ' + repo.split("/")[1] + '</span> ' +
          '<span style="color:var(--fg);">' + (desc ? desc.slice(0, 60) : "") + '</span>' +
          ' <span style="color:var(--dim);font-size:0.7rem;">' + timeStr + '</span>' +
          '</div>';
      }
      el.innerHTML = html;
    })
    .catch(function() { el.innerHTML = '<div style="color:var(--yellow);margin-bottom:0.5rem;">$ curl -s "https://api.github.com/users/LuG3Zz/events?per_page=5"</div><div style="color:var(--dim);font-size:0.8125rem;">failed to fetch activity</div>'; });
})();
</script>
