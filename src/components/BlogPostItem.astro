---
import { statSync } from "fs";
import { join } from "path";

export interface Props {
  post: {
    id: string;
    slug: string;
    data: {
      title: string;
      date: Date;
      image?: string;
      pinned?: boolean;
      password?: string;
    };
  };
  showMeta?: boolean;
}

const { post, showMeta = true } = Astro.props;
const date = post.data.date.toISOString().slice(0, 10);
let sz = "1.2K";
if (showMeta) {
  try { sz = fmtSize(statSync(join(process.cwd(), "src/content/blog", post.id)).size); } catch (_) {}
}
const isPin = post.data.pinned;

function fmtSize(bytes: number): string {
  if (bytes < 1024) return bytes + "B";
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + "K";
  return (bytes / (1024 * 1024)).toFixed(1) + "M";
}
---

<li class="post-item">
  {post.data.image
    ? <img src={post.data.image} alt="" style="width:36px;height:36px;border-radius:4px;object-fit:cover;flex-shrink:0;border:1px solid var(--border);" />
    : <span style="width:36px;height:36px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1.2rem;">{post.data.password ? "🔒" : "📄"}</span>
  }
  {showMeta && (
    <span style={isPin ? "color:var(--yellow);font-size:0.65rem;white-space:nowrap;" : "color:var(--dim);font-size:0.65rem;white-space:nowrap;"}>{isPin ? "drwxr-xr-x" : "-rw-r--r--"} 1 guest guest {sz.padStart(7)}</span>
  )}
  <a class="post-title" href={`/blog/${post.slug}`} style={isPin ? "color:var(--yellow);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" : "overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"}>
    {post.data.title}
  </a>
  {isPin && <span style="color: var(--yellow); font-size: 0.75rem; flex-shrink:0;">[Pinned]</span>}
  <span class="post-date" style="margin-left: auto;flex-shrink:0;">{date}</span>
</li>
