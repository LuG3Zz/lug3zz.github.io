<script is:inline>
  const input = document.getElementById("cmd-input");
  const toast = document.getElementById("cmd-toast");
  const toastMsg = document.getElementById("toast-msg");

  function hideToast() {
    toast.classList.remove("show");
  }

  function showToast(msg) {
    toastMsg.textContent = msg;
    toast.classList.add("show");
  }

  toast.addEventListener("click", hideToast);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") hideToast();
  });

  // Weather
  function windArrow(dir) {
    const m = { N:"↓", NNE:"↙", NE:"↙", ENE:"←", E:"←", ESE:"↖", SE:"↖", SSE:"↑", S:"↑", SSW:"↗", SW:"↗", WSW:"→", W:"→", WNW:"↘", NW:"↘", NNW:"↓" };
    return m[dir] || "―";
  }
  function weatherEmoji(desc) {
    const d = desc.toLowerCase();
    if (d.includes("sunny") || d.includes("clear") || d.includes("晴")) return "☀️";
    if (d.includes("rain") || d.includes("drizzle") || d.includes("shower") || d.includes("雨") || d.includes("阵雨")) return "🌧️";
    if (d.includes("snow") || d.includes("sleet") || d.includes("ice") || d.includes("雪") || d.includes("冰")) return "❄️";
    if (d.includes("thunder") || d.includes("storm") || d.includes("雷") || d.includes("暴")) return "⛈️";
    if (d.includes("fog") || d.includes("mist") || d.includes("haze") || d.includes("雾") || d.includes("霾")) return "🌫️";
    if (d.includes("cloud") || d.includes("overcast") || d.includes("云") || d.includes("阴")) return "☁️";
    return "🌤️";
  }
  const weatherEl = document.getElementById("weather-body");
  if (weatherEl) {
    function fetchWeather(url) {
      var ac = new AbortController();
      setTimeout(function() { ac.abort(); }, 8000);
      fetch(url, { signal: ac.signal })
        .then(function(r) { return r.json(); })
        .then(function(j) {
          var cc = j.current_condition[0];
          var city = j.nearest_area?.[0]?.areaName?.[0]?.value || "";
          var region = j.nearest_area?.[0]?.region?.[0]?.value || "";
          var loc = city + (city && region && region !== city ? ", " + region : region ? ", " + region : "");
          var desc = (cc.lang_zh?.[0]?.value) || cc.weatherDesc[0].value;
          var emoji = weatherEmoji(desc);
          var wind = windArrow(cc.winddir16Point) + " " + cc.windspeedKmph + " km/h";
          weatherEl.innerHTML = '<div>' + (loc ? loc + "  " : "") + emoji + " " + desc + '</div>' +
            '<div>🌡️ ' + cc.temp_C + '°C</div>' +
            '<div>💧 ' + cc.humidity + '%  ·  🌀 ' + wind + '</div>';
        })
        .catch(function() { weatherEl.textContent = "☁️ --.-°C"; });
    }
    var savedCity = localStorage.getItem("weather-city");
    if (savedCity) {
      fetchWeather("https://wttr.in/" + encodeURIComponent(savedCity) + "?format=j1&lang=zh");
    } else if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        function(pos) {
          // Round to 1 decimal (~11km resolution) for city-level only
          var lat = Math.round(pos.coords.latitude * 10) / 10;
          var lng = Math.round(pos.coords.longitude * 10) / 10;
          fetchWeather("https://wttr.in/" + lat + "," + lng + "?format=j1&lang=zh");
          localStorage.setItem("weather-city", lat + "," + lng);
        },
        function() { fetchWeather("https://wttr.in/?format=j1&lang=zh"); },
        { timeout: 8000, enableHighAccuracy: true }
      );
    } else {
      fetchWeather("https://wttr.in/?format=j1&lang=zh");
    }
  }

  // ─── Gist cloud sync ──────────────────────────
  var gistData = null;

  function localKey() { return "brownlu-data"; }

  function defaultGistData() {
    return { todos: [], habits: {}, moods: {}, posts: [], pomodoros: {}, passwordHash: null, encryptedPat: null };
  }

  function toggleMode(attr, onMsg, offMsg) {
    var on = document.documentElement.getAttribute(attr) !== "true";
    document.documentElement.setAttribute(attr, on ? "true" : "false");
    localStorage.setItem(attr.replace("data-", ""), on ? "true" : "false");
    showToast(on ? onMsg : offMsg);
  }

  function applyTheme(name) {
    document.documentElement.setAttribute("data-theme", name);
    localStorage.setItem("theme", name);
    var sel = document.getElementById("theme-select");
    if (sel) sel.value = name;
  }

  // ─── Data persistence ──────────────────────
  function loadLocal() {
    try { return JSON.parse(localStorage.getItem(localKey())) || null; } catch(e) { return null; }
  }

  function saveLocal(data) {
    try { localStorage.setItem(localKey(), JSON.stringify(data)); return true; } catch(e) { return false; }
  }

  function ensureData() {
    if (!gistData) { gistData = loadLocal() || defaultGistData(); }
  }

  function updatePrompt() {
    var el = document.getElementById("prompt-user");
    if (el) el.textContent = localStorage.getItem("logged-in") === "true" ? (localStorage.getItem("gist-user") || "root") : "guest";
  }

  // ─── Crypto ────────────────────────────────
  function sha256(str) {
    return crypto.subtle.digest("SHA-256", new TextEncoder().encode(str)).then(function(buf) {
      return Array.from(new Uint8Array(buf)).map(function(b) { return b.toString(16).padStart(2, "0"); }).join("");
    });
  }

  function xorEncrypt(text, keyHex) {
    var key = [];
    for (var i = 0; i < keyHex.length; i += 2) key.push(parseInt(keyHex.substring(i, i + 2), 16));
    var bytes = new TextEncoder().encode(text);
    var r = "";
    for (var i = 0; i < bytes.length; i++) r += String.fromCharCode(bytes[i] ^ key[i % key.length]);
    return btoa(r);
  }

  function xorDecrypt(cipher, keyHex) {
    var key = [];
    for (var i = 0; i < keyHex.length; i += 2) key.push(parseInt(keyHex.substring(i, i + 2), 16));
    var raw = atob(cipher);
    var bytes = new Uint8Array(raw.length);
    for (var i = 0; i < raw.length; i++) bytes[i] = raw.charCodeAt(i) ^ key[i % key.length];
    return new TextDecoder().decode(bytes);
  }

  // ─── Gist sync ─────────────────────────────
  function fetchGistJson(gid) {
    return fetch("https://api.github.com/gists/" + gid).then(function(res) {
      if (res.status === 401) return null;
      return res.json();
    }).then(function(json) {
      if (!json || !json.files || !json.files["data.json"]) return null;
      try { return JSON.parse(json.files["data.json"].content); } catch(e) { return null; }
    });
  }

  function loadGist(gid) {
    if (!gid) gid = localStorage.getItem("gist-id");
    if (!gid) { gistData = loadLocal() || defaultGistData(); return Promise.resolve(gistData); }
    return fetchGistJson(gid).then(function(payload) {
      if (!payload) { gistData = loadLocal() || defaultGistData(); return gistData; }
      var key = localStorage.getItem("gist-key");
      if (payload.v === 1 && payload.h) {
        if (!key) { gistData = loadLocal() || defaultGistData(); return gistData; }
        if (key !== payload.h) { gistData = loadLocal() || defaultGistData(); return gistData; }
        gistData = payload.d ? JSON.parse(xorDecrypt(payload.d, key)) : defaultGistData();
      } else {
        if (key && payload.passwordHash && key !== payload.passwordHash) { gistData = loadLocal() || defaultGistData(); return gistData; }
        gistData = payload;
      }
      saveLocal(gistData);
      return gistData;
    });
  }

  function findGistByUser(username) {
    var url = "https://api.github.com/users/" + encodeURIComponent(username) + "/gists?per_page=30";
    return fetch(url).then(function(r) { return r.json(); }).then(function(gists) {
      if (!Array.isArray(gists)) return null;
      for (var i = 0; i < gists.length; i++) {
        if (gists[i].files["data.json"]) return gists[i];
      }
      return null;
    });
  }

  function saveGist(data) {
    var gid = localStorage.getItem("gist-id");
    var pat = localStorage.getItem("gist-pat");
    if (!gid || !pat) { saveLocal(data); return Promise.resolve(true); }
    var key = localStorage.getItem("gist-key");
    var payload;
    if (key) {
      payload = { v: 1, h: key, d: xorEncrypt(JSON.stringify(data), key) };
    } else {
      payload = data;
    }
    var body = JSON.stringify({ files: { "data.json": { content: JSON.stringify(payload) } } });
    return fetch("https://api.github.com/gists/" + gid, {
      method: "PATCH", headers: { "Authorization": "token " + pat, "Content-Type": "application/json" }, body: body
    }).then(function(r) { var ok = r.status === 200; if (ok) saveLocal(data); return ok; });
  }

  function hasGist() {
    return localStorage.getItem("gist-pat") && localStorage.getItem("gist-id");
  }

  // ─── Display utilities ─────────────────────
  function strWidth(s) {
    var w = 0;
    for (var i = 0; i < s.length; i++) {
      var c = s.charCodeAt(i);
      if ((c & 0xfc00) === 0xd800) { w += 2; i++; }
      else if ((c >= 0x4e00 && c <= 0x9fff) || (c >= 0x3000 && c <= 0x303f) || (c >= 0xff00 && c <= 0xffef) || (c >= 0x2600 && c <= 0x27bf) || c === 0x23f0 || c === 0x23f3) { w += 2; }
      else { w += 1; }
    }
    return w;
  }

  function rep(ch, n) { var r = ""; for (var i = 0; i < n; i++) r += ch; return r; }

  function wrapBox(lines, title) {
    var w = 2;
    for (var i = 0; i < lines.length; i++) { var sw = strWidth(lines[i]); if (sw > w) w = sw; }
    w = Math.min(w, 60);
    var r = [];
    r.push("\u250c" + (title ? "\u2500 " + title + " " + rep("\u2500", Math.max(0, w - strWidth(title) - 3)) : rep("\u2500", w)) + "\u2510");
    for (var i = 0; i < lines.length; i++) r.push("\u2502" + lines[i] + rep(" ", w - strWidth(lines[i])) + "\u2502");
    r.push("\u2514" + rep("\u2500", w) + "\u2518");
    return r;
  }

  function renderBar(label, value, max, total) {
    var barW = 15;
    var filled = max > 0 ? Math.round(value / max * barW) : 0;
    return " " + label + " " + rep("\u2588", filled) + rep("\u2591", barW - filled) + " " + value + (total ? "/" + total : "");
  }

  // ─── Todo helpers ──────────────────────────
  function parseTodoArgs(input) {
    var parts = input.trim().split(/\s+/);
    var text = [], priority = "medium", tags = [], dueDate = null;
    for (var i = 0; i < parts.length; i++) {
      if (parts[i] === "--high") priority = "high";
      else if (parts[i] === "--low") priority = "low";
      else if (parts[i].startsWith("#")) tags.push(parts[i].slice(1));
      else if (parts[i] === "--due" && parts[i + 1]) { dueDate = parts[i + 1]; i++; }
      else text.push(parts[i]);
    }
    return { text: text.join(" "), priority: priority, tags: tags, dueDate: dueDate };
  }

  function todoLine(n, t) {
    var line = (n < 10 ? " " : "") + n + ". " + (t.done ? "[x]" : "[ ]") + " " + t.text;
    if (t.priority === "high") line += " \u26a0";
    if (t.priority === "low") line += " \u2193";
    if (t.tags && t.tags.length) line += " #" + t.tags.join(" #");
    if (t.dueDate) {
      var overdue = !t.done && t.dueDate < new Date().toISOString().slice(0, 10);
      line += " (" + (overdue ? "\u23f0" : "\ud83d\udcc5") + " " + t.dueDate + (overdue ? " OVERDUE" : "") + ")";
    }
    return line;
  }

  function showInTodo(label, html) {
    var el = document.getElementById("info-left");
    var head = document.getElementById("todo-head");
    var body = document.getElementById("todo-body");
    if (!el || !head || !body) return;
    head.setAttribute("data-label", label);
    head.textContent = "[-] " + label;
    head.style.display = "";
    body.innerHTML = html;
    el.classList.add("visible");
    document.getElementById("left-toggle")?.classList.add("active");
    alignSidebars();
    renderProfile();
  }

  function showInTodoText(label, text) {
    var el = document.getElementById("info-left");
    var head = document.getElementById("todo-head");
    var body = document.getElementById("todo-body");
    if (!el || !head || !body) return;
    head.setAttribute("data-label", label);
    head.textContent = "[-] " + label;
    head.style.display = "";
    body.textContent = text;
    el.classList.add("visible");
    document.getElementById("left-toggle")?.classList.add("active");
    alignSidebars();
    renderProfile();
  }

  function renderTodos(filter) {
    if (!gistData || !gistData.todos) return;
    var todos = gistData.todos;
    var indices = [];
    for (var i = 0; i < todos.length; i++) {
      var t = todos[i];
      if (filter) {
        if (filter.tag && (t.tags || []).indexOf(filter.tag) === -1) continue;
        if (filter.priority && t.priority !== filter.priority) continue;
        if (filter.overdue) {
          if (t.done || !t.dueDate || t.dueDate >= new Date().toISOString().slice(0, 10)) continue;
        }
      }
      indices.push(i);
    }
    var html = "";
    for (var di = 0; di < indices.length; di++) {
      var idx = indices[di];
      html += escHtml(todoLine(idx + 1, todos[idx]));
      if (di < indices.length - 1) html += "\n";
    }
    var label = "todos";
    if (filter) {
      var parts = [];
      if (filter.tag) parts.push("#" + filter.tag);
      if (filter.priority) parts.push(filter.priority);
      if (filter.overdue) parts.push("overdue");
      if (parts.length) label += " (" + parts.join(", ") + ")";
    }
    if (indices.length === 0 && !filter) label += " (empty)";
    showInTodo(label, html || "(no matches)");
  }

  function gistMutate(okMsg, afterSave) {
    return saveGist(gistData).then(function(ok) {
      if (ok) showToast(okMsg);
      else showToast("save failed");
      if (afterSave) afterSave();
      return ok;
    });
  }

  function todoMutate(okMsg) {
    return gistMutate(okMsg, renderTodos);
  }

  function renderHabitList() {
    if (!gistData || !gistData.habits) return;
    var hkeys = Object.keys(gistData.habits);
    if (hkeys.length === 0) { showToast("no habits. type: habit add <name>"); return; }
    var today = new Date().toISOString().slice(0, 10), hlines = [];
    for (var hi = 0; hi < hkeys.length; hi++) hlines.push((hi + 1) + ". " + (gistData.habits[hkeys[hi]][today] ? "[x]" : "[ ]") + " " + hkeys[hi]);
    showInTodoText("habits", hlines.join("\n"));
  }

  function renderPostList() {
    if (!gistData || !gistData.posts || gistData.posts.length === 0) { showToast("no posts yet. type: post <text>"); return; }
    var lines = [];
    for (var pi = 0; pi < Math.min(gistData.posts.length, 10); pi++) {
      var idx = gistData.posts.length - 1 - pi;
      var p = gistData.posts[idx];
      var d = new Date(p.createdAt);
      lines.push((pi + 1) + ". [" + d.toISOString().slice(0, 10) + " " + String(d.getHours()).padStart(2, "0") + ":" + String(d.getMinutes()).padStart(2, "0") + "] " + p.text);
    }
    showInTodoText("posts", lines.join("\n"));
    showToast("showing " + Math.min(gistData.posts.length, 10) + "/" + gistData.posts.length + " posts");
  }

  // ─── Panel toggle ──────────────────────────
  function togglePanel(side) {
    var panel = document.getElementById("info-" + side);
    var toggle = document.getElementById(side + "-toggle");
    if (!panel || !toggle) return;
    var visible = panel.classList.contains("visible");
    if (visible) {
      panel.classList.remove("visible");
      toggle.textContent = side === "left" ? "\u25b6" : "\u25c0";
    } else {
      panel.classList.add("visible");
      toggle.textContent = side === "left" ? "\u25b6" : "\u25c0";
      alignSidebars();
    }
  }

  function expandPanel(side) {
    var panel = document.getElementById("info-" + side);
    var toggle = document.getElementById(side + "-toggle");
    if (!panel || !toggle) return;
    if (panel.classList.contains("visible")) return;
    panel.classList.add("visible");
    toggle.textContent = side === "left" ? "\u25b6" : "\u25c0";
    toggle.classList.add("active");
    alignSidebars();
  }
  }

  function expandPanel(side) {
    var panel = document.getElementById("info-" + side);
    var toggle = document.getElementById(side + "-toggle");
    var resizer = document.getElementById(side + "-resizer");
    if (!panel || !toggle) return;
    if (panel.classList.contains("visible")) return;
    panel.classList.add("visible");
    toggle.textContent = side === "left" ? "\u25c0" : "\u25b6";
    if (resizer) resizer.style.display = "block";
    toggle.classList.add("active");
    alignSidebars();
  }

  function getTodoStats() {
    var todos = gistData.todos || [], archived = gistData.archived || [];
    var done = todos.filter(function(t) { return t.done; }).length;
    var pending = todos.filter(function(t) { return !t.done; });
    var totalDone = done + archived.length;
    var total = todos.length + archived.length;
    var byPrio = { high: 0, medium: 0, low: 0 };
    pending.forEach(function(t) { byPrio[t.priority || "medium"]++; });
    var byTag = {};
    todos.forEach(function(t) { (t.tags || []).forEach(function(tag) { byTag[tag] = (byTag[tag] || 0) + 1; }); });
    var noDue = !todos.some(function(t) { return !t.done && t.dueDate; });
    return { total: total, totalDone: totalDone, done: done, pending: pending.length, byPrio: byPrio, byTag: byTag, archived: archived.length, noDue: noDue, todos: todos };
  }

  function getTodoWeek() {
    var today = new Date(), dayNames = ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"], wlines = [];
    for (var wi = 6; wi >= 0; wi--) {
      var d = new Date(today); d.setDate(d.getDate() - wi);
      var dateKey = d.getFullYear() + "-" + String(d.getMonth() + 1).padStart(2, "0") + "-" + String(d.getDate()).padStart(2, "0");
      var tCount = 0;
      if (gistData.todos) for (var tj = 0; tj < gistData.todos.length; tj++) { var td = gistData.todos[tj]; if (td.createdAt) { var cd = new Date(td.createdAt); if (cd.getFullYear() === d.getFullYear() && cd.getMonth() === d.getMonth() && cd.getDate() === d.getDate()) tCount++; } }
      var pCount = (gistData.pomodoros && gistData.pomodoros[dateKey]) || 0;
      wlines.push(" " + (wi === 0 ? "\u2192" : " ") + " " + dayNames[d.getDay()] + " " + String(d.getDate()).padStart(2, " ") + "    todo:" + (tCount || "-") + "  pomo:" + (pCount || "-"));
    }
    return wlines;
  }

  function renderTodoCalendar(year, month) {
    var el = document.getElementById("info-left");
    if (!el) return;
    var today = new Date();
    var daysInMonth = new Date(year, month + 1, 0).getDate();
    var firstDay = (new Date(year, month, 1).getDay() + 6) % 7;
    var monthNames = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    var lines = [];
    lines.push("     " + monthNames[month] + " " + year);
    lines.push(" Mo Tu We Th Fr Sa Su");
    var week = "";
    for (var i = 0; i < firstDay; i++) week += "   ";
    for (var d = 1; d <= daysInMonth; d++) {
      var dateKey = year + "-" + String(month + 1).padStart(2, "0") + "-" + String(d).padStart(2, "0");
      var count = 0;
      if (gistData.todos) for (var tj = 0; tj < gistData.todos.length; tj++) { var t = gistData.todos[tj]; if (t.createdAt) { var cd = new Date(t.createdAt); if (cd.getFullYear() === year && cd.getMonth() === month && cd.getDate() === d) count++; } }
      var pomos = (gistData.pomodoros && gistData.pomodoros[dateKey]) || 0;
      var cell = (d < 10 ? " " : "") + d + " ";
      if (count > 0 || pomos > 0) {
        var dots = "";
        if (count > 0) dots += "\u25cf";
        if (pomos > 0) dots += "\ud83c\udf4d";
        cell = (d < 10 ? " " : "") + d + dots.slice(0, 2);
      }
      week += cell.length > 3 ? cell.slice(0, 3) : cell;
      if ((firstDay + d) % 7 === 0 || d === daysInMonth) { lines.push(week); week = ""; }
    }
    lines.push(" \u25cf=todo \ud83c\udf4d=pomo");
    lines.push("");
    // Show recent items
    var dayItems = {};
    for (var di = 0; di < (gistData.todos || []).length; di++) {
      var t = gistData.todos[di];
      if (t.createdAt) { var cd = new Date(t.createdAt); var key = cd.getMonth() + "-" + cd.getDate(); if (!dayItems[key]) dayItems[key] = []; dayItems[key].push(t); }
    }
    var todayKey = today.getMonth() + "-" + today.getDate();
    var recentKeys = Object.keys(dayItems).filter(function(k) { return k !== todayKey; }).slice(-3);
    recentKeys.push(todayKey);
    var listHtml = "";
    for (var mi = 0; mi < recentKeys.length; mi++) {
      var parts = recentKeys[mi].split("-");
      var month = parseInt(parts[0]), dayN = parseInt(parts[1]);
      var items = dayItems[recentKeys[mi]] || [];
      listHtml += '<div style="color:var(--yellow);font-size:0.75rem;margin-bottom:0.25rem;">' + monthNames[month] + " " + dayN + '</div>';
      for (var j = 0; j < items.length; j++) {
        var t = items[j];
        listHtml += '<div style="padding-left:0.5rem;font-size:0.75rem;line-height:1.5;">' + (t.done ? "[x]" : "[ ]") + " " + (t.text) + '</div>';
      }
    }
    showInTodo("calendar", (listHtml ? '<div style="display:flex;gap:1.5rem;align-items:flex-start;"><pre style="margin:0;background:none;border:none;padding:0;font-size:0.8125rem;white-space:pre;">' + lines.join("\n") + '</pre><div style="flex:1;min-width:0;">' + listHtml + '</div></div>' : '<pre style="margin:0;background:none;border:none;padding:0;font-size:0.8125rem;white-space:pre;">' + lines.join("\n") + '</pre>'));
  }

  function renderMoodCalendar() {
    var el = document.getElementById("info-left");
    if (!el || !gistData || !gistData.moods) return;
    var today = new Date();
    var year = today.getFullYear(), month = today.getMonth();
    var daysInMonth = new Date(year, month + 1, 0).getDate();
    var monthNames = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    var firstDay = (new Date(year, month, 1).getDay() + 6) % 7;
    var moodCh = ["\ud83d\ude1e","\ud83d\ude10","\ud83d\ude42","\ud83d\ude0a","\ud83d\ude04"];
    var lines = [];
    lines.push("      " + monthNames[month] + " " + year);
    lines.push(" Mo Tu We Th Fr Sa Su");
    var week = "";
    for (var i = 0; i < firstDay; i++) week += "   ";
    for (var d = 1; d <= daysInMonth; d++) {
      var dateKey = year + "-" + String(month + 1).padStart(2, "0") + "-" + String(d).padStart(2, "0");
      var m = gistData.moods[dateKey];
      var cell = (d < 10 ? " " : "") + d + " ";
      if (m >= 1 && m <= 5) cell = moodCh[m - 1] + " ";
      else if (d === today.getDate()) cell = " \u25cb ";
      week += cell;
      if ((firstDay + d) % 7 === 0 || d === daysInMonth) { lines.push(week); week = ""; }
    }
    lines.push(" \ud83d\ude1e \ud83d\ude10 \ud83d\ude42 \ud83d\ude0a \ud83d\ude04  \u25cb today no record");
    showInTodoText("mood", lines.join("\n"));
  }

  // ─── Image to ASCII ──────────────────────
  function imageToAscii(url, callback) {
    var img = new Image();
    img.crossOrigin = "anonymous";
    img.onload = function() {
      var c = document.createElement('canvas');
      var w = 48, h = Math.round(img.height / img.width * w * 0.45);
      c.width = w; c.height = h;
      var ctx = c.getContext('2d');
      ctx.drawImage(img, 0, 0, w, h);
      var d = ctx.getImageData(0, 0, w, h).data;
      var chars = "@%#*+=-:. ", out = "";
      for (var y = 0; y < h; y++) {
        for (var x = 0; x < w; x++) {
          var i = (y * w + x) * 4;
          var b = (d[i] + d[i+1] + d[i+2]) / 3;
          out += chars[Math.floor(b / 255 * (chars.length - 1))];
        }
        out += "\n";
      }
      callback(out);
    };
    img.onerror = function() { callback("(avatar load failed)"); };
    img.src = url;
  }

  // ─── Default ASCII avatar by seed ────────
  function defaultAsciiAvatar(seed) {
    var avatars = [
      '    .--.\n   /    \\\n  | o  o |\n  |  __  |\n   \\    /\n    `--\'',
      '   |\\---/|\n   | o o |\n   \\_ W _/\n     ||\n    (__)',
      '   .-""""-.\n  /        \\\n |  O    O |\n |    <>   |\n  \\ """" /\n   \'----\'',
      '    /\\_/\\\n   (=o.o=)\n   ( >.< )\n    "--"',
      '   ┌─┐ ┌─┐\n   │ │ │ │\n   └─┘ └─┘\n    ────'
    ];
    var idx = 0;
    if (seed) for (var i = 0; i < seed.length; i++) idx = (idx + seed.charCodeAt(i)) % avatars.length;
    return avatars[idx];
  }

  // ─── Profile rendering ────────────────────
  function renderProfile() {
    var loggedIn = localStorage.getItem("logged-in") === "true";
    var right = document.getElementById("info-right");
    if (!right) return;
    if (!loggedIn) { renderAuthorInfo(); right.style.display = "block"; }
    else { renderUserProfile(); right.style.display = "block"; }
    expandPanel("right");
  }

  function renderAuthorInfo() {
    var avatar = localStorage.getItem("avatar-ascii") || defaultAsciiAvatar("");
    var html = '<pre style="font-size:0.6rem;line-height:1.1;color:var(--cyan);margin:0 0 0.5rem 0;">' + escHtml(avatar) + '</pre>';
    html += '<div style="border-top:1px dashed var(--border);margin:0.5rem 0;"></div>';
    html += '<div style="font-size:0.75rem;line-height:1.8;">';
    html += 'author: <span style="color:var(--green)">lug3zz</span><br>';
    html += '<span style="color:var(--dim);font-size:0.65rem;">\u559c\u6b22\u5199\u4ee3\u7801\u3001\u6298\u817e\u7ec8\u7aef</span><br>';
    html += '<a href="/about" style="color:var(--blue)">/about</a><br>';
    html += '<a href="https://github.com/LuG3Zz" style="color:var(--dim);font-size:0.65rem;">github.com/LuG3Zz</a>';
    html += '</div>';
    document.getElementById("profile-content").innerHTML = html;
  }

  function renderUserProfile() {
    var avatar = localStorage.getItem("avatar-ascii") || defaultAsciiAvatar("user");
    var username = localStorage.getItem("gist-user") || "user";
    var html = '<pre style="font-size:0.6rem;line-height:1.1;color:var(--cyan);margin:0 0 0.5rem 0;">' + escHtml(avatar) + '</pre>';
    html += '<div style="border-top:1px dashed var(--border);margin:0.5rem 0;"></div>';
    html += '<div style="font-size:0.75rem;line-height:1.8;">';
    html += 'user: <span style="color:var(--green)">' + escHtml(username) + '</span><br>';
    html += 'status: <span style="color:var(--green)">logged in</span><br>';
    var uptimeEl = document.getElementById("footer-uptime");
    html += 'uptime: ' + (uptimeEl ? uptimeEl.textContent : "--") + '<br>';
    html += 'date: ' + new Date().toISOString().slice(0, 10) + '<br>';
    html += '</div>';
    if (gistData) {
      html += '<div style="border-top:1px dashed var(--border);margin:0.5rem 0;"></div>';
      html += '<div style="font-size:0.75rem;line-height:1.8;"><span style="color:var(--yellow)">\u2014\u2014 stats \u2014\u2014</span><br>';
      var todos = gistData.todos || [];
      var doneTodos = todos.filter(function(t) { return t.done; }).length;
      html += 'todos: ' + doneTodos + '/' + todos.length + '<br>';
      var today = new Date().toISOString().slice(0, 10);
      var habitKeys = gistData.habits ? Object.keys(gistData.habits) : [];
      var doneHabits = 0;
      for (var hi = 0; hi < habitKeys.length; hi++) {
        if (gistData.habits[habitKeys[hi]][today]) doneHabits++;
      }
      html += 'habits: ' + doneHabits + '/' + habitKeys.length + '<br>';
      var pomos = (gistData.pomodoros && gistData.pomodoros[today]) || 0;
      html += 'pomos: ' + pomos + '<br>';
      html += '</div>';
    }
    document.getElementById("profile-content").innerHTML = html;
  }

  // ─── Sidebar alignment ────────────────────
  function alignSidebars() {
    var nav = document.querySelector('.nav');
    if (!nav) return;
    var navBottom = nav.getBoundingClientRect().bottom;
    ["info-left","info-right","left-toggle","right-toggle"].forEach(function(id) {
      var el = document.getElementById(id);
      if (el && el.style.display !== "none") {
        el.style.top = navBottom + "px";
        el.style.height = "calc(100vh - " + navBottom + "px)";
      }
    });
  }

  // ─── Panel focus guard ────────────────────
  function initPanelFocusGuard() {
    ["info-left","info-right","info-left-content","info-right-content"].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.addEventListener("mousedown", function(e) { e.stopPropagation(); });
    });
  }

</script>
